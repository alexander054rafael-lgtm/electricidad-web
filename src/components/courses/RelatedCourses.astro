---
import CourseGrid from './CourseGrid.astro';
import type { Course } from '../../data/courses';
interface Props { courses: Course[] }
const { courses } = Astro.props;
---

{courses.length > 0 && (
  <section class="related-courses">
    <CourseGrid courses={courses} title="Cursos relacionados" subtitle="Continúa construyendo una ruta técnica conectada con este programa." />
  </section>
)}

<style>
  .related-courses { margin-top:clamp(4rem,8vw,7rem); padding-top:clamp(3rem,6vw,5rem); border-top:1px solid var(--color-border); }
</style>

---
import { ArrowLeft, BookOpen, Check, CirclePlay, Clock3, Cog, GraduationCap, Layers, Sparkles, UserRound, Zap } from '@lucide/astro';
import Button from '../ui/Button.astro';
import Container from '../ui/Container.astro';
import type { Course } from '../../data/courses';
import { getLessonCount } from '../../data/courses';

interface Props { course?: Course; courseCount?: number }
const { course, courseCount = 0 } = Astro.props;
---

{course ? (
  <section class="course-hero course-hero--detail" style={`--course-accent:${course.accent}`}>
    <Container>
      <a class="course-hero__back" href="/cursos"><ArrowLeft size={16} aria-hidden="true" /> Todos los cursos</a>
      <div class="course-hero__detail-grid">
        <div class="course-hero__content">
          <span class="course-hero__eyebrow"><GraduationCap size={17} aria-hidden="true" /> {course.category}</span>
          <h1>{course.title}</h1>
          <p class="course-hero__description">{course.description}</p>
          <div class="course-hero__facts">
            <span><Clock3 size={18} aria-hidden="true" /><strong>{course.duration}</strong><small>Duración</small></span>
            <span><Layers size={18} aria-hidden="true" /><strong>{course.modules.length} módulos</strong><small>Contenido</small></span>
            <span><BookOpen size={18} aria-hidden="true" /><strong>{getLessonCount(course)} lecciones</strong><small>Clases</small></span>
            <span><UserRound size={18} aria-hidden="true" /><strong>{course.level}</strong><small>Nivel</small></span>
          </div>
          <div class="course-hero__actions">
            <form class="course-hero__enroll" method="post" action="/api/courses/enroll"><input type="hidden" name="courseSlug" value={course.slug} /><button type="submit"><CirclePlay size={19} aria-hidden="true" /> Inscribirme y comenzar</button></form>
            <span>Instructor: <strong>{course.instructor}</strong></span>
          </div>
        </div>
        <div class="course-hero__cover">
          <img src={course.image} alt={`Portada del curso ${course.title}`} />
          <div class="course-hero__cover-overlay"><span>{course.badge}</span><strong>{course.title}</strong><small>InduTech Academy</small></div>
        </div>
      </div>
    </Container>
  </section>
) : (
  <section class="course-hero">
    <div class="course-hero__orb course-hero__orb--one" aria-hidden="true"></div>
    <div class="course-hero__orb course-hero__orb--two" aria-hidden="true"></div>
    <Container>
      <div class="course-hero__listing-grid">
        <div>
          <span class="course-hero__eyebrow"><Sparkles size={17} aria-hidden="true" /> Formación técnica aplicada</span>
          <h1>Cursos <span>Técnicos</span></h1>
          <p class="course-hero__description">Aprende con rutas claras, proyectos reales y contenido creado para los desafíos de la industria. Avanza desde los fundamentos hasta la aplicación en campo.</p>
          <div class="course-hero__listing-actions">
            <Button href="#catalogo" variant="primary" size="lg">Explorar cursos</Button>
            <span><strong>{courseCount}</strong> {courseCount === 1 ? 'programa disponible' : 'programas disponibles'}</span>
          </div>
        </div>
        <div class="course-hero__visual" aria-hidden="true">
          <div class="course-hero__dashboard">
            <div class="course-hero__dashboard-topline">
              <span><GraduationCap size={17} stroke-width={1.8} /> Ruta de aprendizaje</span>
              <span class="course-hero__lesson-count"><BookOpen size={15} stroke-width={1.8} /> 12 lecciones</span>
            </div>
            <h2>Electricidad industrial</h2>
            <div class="course-hero__progress">
              <div><span>Progreso del curso</span><strong>72 %</strong></div>
              <div class="course-hero__progress-track"><i></i></div>
            </div>
            <div class="course-hero__steps">
              <div class="course-hero__step course-hero__step--complete">
                <span class="course-hero__step-icon"><BookOpen size={18} stroke-width={1.8} /></span>
                <span><small>Paso 01</small><strong>Fundamentos eléctricos</strong></span>
                <span class="course-hero__step-check"><Check size={15} stroke-width={2.4} /></span>
              </div>
              <div class="course-hero__step course-hero__step--active">
                <span class="course-hero__step-icon"><Zap size={18} stroke-width={1.8} /></span>
                <span><small>Paso 02</small><strong>Instalación y control</strong></span>
                <i aria-hidden="true"></i>
              </div>
              <div class="course-hero__step">
                <span class="course-hero__step-icon"><Cog size={18} stroke-width={1.8} /></span>
                <span><small>Paso 03</small><strong>Aplicación práctica</strong></span>
                <i aria-hidden="true"></i>
              </div>
            </div>
          </div>
          <div class="course-hero__floating"><span><Check size={17} stroke-width={2.4} /></span><strong>Aprende paso a paso</strong></div>
        </div>
      </div>
    </Container>
  </section>
)}

<style>
  .course-hero { position:relative; isolation:isolate; overflow:hidden; padding:clamp(8.5rem,14vw,12rem) 0 clamp(4rem,8vw,6.5rem); background:radial-gradient(circle at 14% 16%,var(--hero-ambient-green),transparent 34rem),radial-gradient(circle at 88% 18%,var(--hero-ambient-blue),transparent 32rem),linear-gradient(180deg,var(--hero-bg-start) 0%,var(--hero-bg-mid) 68%,var(--hero-bg-end) 100%); }
  .course-hero__listing-grid,.course-hero__detail-grid { display:grid; align-items:center; gap:clamp(2rem,5vw,5rem); }
  .course-hero__listing-grid { grid-template-columns:minmax(0,1.15fr) minmax(310px,.65fr); }
  .course-hero__eyebrow { display:inline-flex; align-items:center; gap:.45rem; padding:.42rem .82rem; border:1px solid var(--hero-card-border); border-radius:var(--radius-full); background:var(--hero-card-surface); color:var(--hero-card-primary); font-size:.78rem; font-weight:750; }
  h1 { max-width:900px; margin:1.1rem 0 1rem; font-size:clamp(2.8rem,7vw,5.5rem); font-weight:800; letter-spacing:-.06em; text-wrap:balance; }
  h1 span { color:var(--color-primary); }
  .course-hero__description { max-width:760px; color:var(--color-text-secondary); font-size:clamp(1rem,1.7vw,1.2rem); line-height:1.72; }
  .course-hero__listing-actions,.course-hero__actions { display:flex; align-items:center; flex-wrap:wrap; gap:1.25rem; margin-top:1.8rem; }
  .course-hero__enroll button{display:inline-flex;align-items:center;gap:.5rem;min-height:52px;padding:.8rem 1.35rem;border-radius:var(--radius-full);background:var(--color-primary);color:#fff;font-size:.9rem;font-weight:800;box-shadow:0 8px 24px rgba(22,163,74,.24);transition:transform var(--transition-fast),background var(--transition-fast)}.course-hero__enroll button:hover{transform:translateY(-2px);background:var(--color-primary-dark)}
  .course-hero__listing-actions>span,.course-hero__actions>span { color:var(--color-text-secondary); font-size:.88rem; }
  .course-hero__listing-actions>span strong { color:var(--color-primary-dark); font-size:1.1rem; }
  .course-hero__visual { position:relative; display:grid; min-width:0; min-height:430px; padding:1.25rem 0 2rem; place-items:center; animation:course-visual-enter .65s cubic-bezier(.22,1,.36,1) both; }
  .course-hero__dashboard { position:relative; width:min(100%,440px); padding:clamp(1.25rem,3vw,1.75rem); overflow:hidden; border:1px solid rgba(34,197,94,.25); border-radius:28px; background:linear-gradient(145deg,#101c30 0%,#0f1b2d 58%,#0c1727 100%); box-shadow:0 30px 70px rgba(15,27,45,.24),0 10px 28px rgba(15,23,42,.16),inset 0 1px 0 rgba(255,255,255,.04); animation:course-dashboard-float 6s ease-in-out .65s infinite; }
  .course-hero__dashboard::before { position:absolute; top:-90px; right:-70px; width:210px; height:210px; border-radius:50%; background:radial-gradient(circle,rgba(34,197,94,.13),rgba(34,197,94,0) 68%); content:''; pointer-events:none; }
  .course-hero__dashboard-topline { position:relative; display:flex; align-items:center; justify-content:space-between; gap:.75rem; color:#94a3b8; font-size:.67rem; font-weight:750; letter-spacing:.035em; }
  .course-hero__dashboard-topline>span { display:inline-flex; align-items:center; gap:.4rem; }
  .course-hero__dashboard-topline>span:first-child { color:#4ade80; text-transform:uppercase; letter-spacing:.08em; }
  .course-hero__lesson-count { flex:none; padding:.35rem .55rem; border:1px solid rgba(148,163,184,.16); border-radius:999px; background:rgba(148,163,184,.07); color:#cbd5e1; }
  .course-hero__dashboard h2 { position:relative; margin:1rem 0 1.35rem; color:#f8fafc; font-size:clamp(1.35rem,2.4vw,1.75rem); letter-spacing:-.035em; }
  .course-hero__progress { position:relative; padding:1rem; border:1px solid rgba(148,163,184,.14); border-radius:16px; background:rgba(15,23,42,.4); }
  .course-hero__progress>div:first-child { display:flex; justify-content:space-between; align-items:center; color:#94a3b8; font-size:.72rem; }
  .course-hero__progress strong { color:#f8fafc; font-size:.78rem; }
  .course-hero__progress-track { height:7px; margin-top:.7rem; overflow:hidden; border-radius:999px; background:#26364d; }
  .course-hero__progress-track i { display:block; width:72%; height:100%; border-radius:inherit; background:linear-gradient(90deg,#22c55e,#4ade80); box-shadow:0 0 18px rgba(74,222,128,.32); }
  .course-hero__steps { position:relative; display:grid; gap:.65rem; margin-top:1rem; }
  .course-hero__step { display:grid; grid-template-columns:auto minmax(0,1fr) auto; align-items:center; gap:.75rem; min-width:0; padding:.72rem .8rem; border:1px solid rgba(148,163,184,.12); border-radius:14px; background:rgba(30,41,59,.58); }
  .course-hero__step--active { border-color:rgba(34,197,94,.34); background:rgba(34,197,94,.08); }
  .course-hero__step-icon { display:grid; width:34px; height:34px; place-items:center; border-radius:10px; background:rgba(34,197,94,.11); color:#4ade80; }
  .course-hero__step>span:nth-child(2) { display:grid; min-width:0; }
  .course-hero__step small { color:#94a3b8; font-size:.58rem; font-weight:750; letter-spacing:.075em; text-transform:uppercase; }
  .course-hero__step strong { overflow:hidden; color:#f8fafc; font-size:.75rem; text-overflow:ellipsis; white-space:nowrap; }
  .course-hero__step>i { width:7px; height:7px; border-radius:50%; background:#475569; }
  .course-hero__step--active>i { background:#22c55e; box-shadow:0 0 0 4px rgba(34,197,94,.12); }
  .course-hero__step-check { display:grid; width:24px; height:24px; place-items:center; border-radius:50%; background:#22c55e; color:#062812; }
  .course-hero__floating { position:absolute; right:-.25rem; bottom:1rem; display:flex; align-items:center; gap:.6rem; padding:.72rem .9rem; border:1px solid rgba(74,222,128,.28); border-radius:14px; background:#13243a; color:#f8fafc; box-shadow:0 16px 34px rgba(15,23,42,.24); font-size:.7rem; animation:course-card-float 4.8s ease-in-out 1s infinite; }
  .course-hero__floating>span { display:grid; width:28px; height:28px; place-items:center; border-radius:9px; background:rgba(34,197,94,.14); color:#4ade80; }
  .course-hero__orb { position:absolute; z-index:-1; border-radius:50%; background:var(--hero-ambient-green); filter:blur(24px); }.course-hero__orb--one{width:320px;height:320px;top:-140px;right:8%}.course-hero__orb--two{width:220px;height:220px;bottom:-100px;left:18%}

  .course-hero--detail { padding:calc(var(--header-height) + clamp(3rem,7vw,5rem)) 0 clamp(4rem,7vw,5.5rem); background:radial-gradient(circle at 85% 18%,color-mix(in srgb,var(--course-accent),transparent 94%),transparent 30rem),linear-gradient(180deg,color-mix(in srgb,var(--hero-bg-start),var(--course-accent) 3%) 0%,var(--hero-bg-mid) 68%,var(--hero-bg-end) 100%); }
  .course-hero__back { display:inline-flex; align-items:center; gap:.4rem; margin-bottom:1.8rem; color:var(--color-text-secondary); font-size:.86rem; font-weight:650; }
  .course-hero__back:hover { color:var(--color-primary); }
  .course-hero__detail-grid { grid-template-columns:minmax(0,1.2fr) minmax(280px,.6fr); }
  .course-hero--detail h1 { max-width:850px; font-size:clamp(2.5rem,5vw,4.65rem); }
  .course-hero__facts { display:grid; grid-template-columns:repeat(4,minmax(110px,1fr)); max-width:760px; gap:.75rem; margin-top:1.8rem; }
  .course-hero__facts>span { display:grid; grid-template-columns:auto 1fr; align-items:center; gap:.05rem .45rem; padding:.8rem; border:1px solid var(--hero-card-border); border-radius:14px; background:var(--hero-card-surface); }
  .course-hero__facts svg { grid-row:1/3; color:var(--hero-card-icon); }.course-hero__facts strong{color:var(--hero-card-primary);font-size:.82rem;opacity:1}.course-hero__facts small{color:var(--hero-card-secondary);font-size:.68rem;opacity:1}
  .course-hero__cover { position:relative; min-height:430px; overflow:hidden; border-radius:32px; background:linear-gradient(145deg,var(--course-accent),#0f172a); box-shadow:0 32px 70px color-mix(in srgb,var(--course-accent),transparent 76%); }
  .course-hero__cover::after { content:''; position:absolute; inset:0; background:linear-gradient(180deg,rgba(15,23,42,.06),rgba(15,23,42,.86)); }
  .course-hero__cover img { width:100%; height:100%; object-fit:cover; opacity:.64; }
  .course-hero__cover-overlay { position:absolute; inset:0; z-index:1; display:flex; flex-direction:column; justify-content:end; padding:2rem; color:#fff; }
  .course-hero__cover-overlay span { align-self:flex-start; margin-bottom:auto; padding:.35rem .7rem; border-radius:999px; background:#fff; color:var(--course-accent); font-size:.7rem; font-weight:800; text-transform:uppercase; }
  .course-hero__cover-overlay strong { font:800 clamp(1.45rem,3vw,2rem)/1.15 var(--font-display); }.course-hero__cover-overlay small{margin-top:.6rem;opacity:.72}
  @keyframes course-visual-enter { from { opacity:0; transform:translateY(18px) scale(.98); } to { opacity:1; transform:translateY(0) scale(1); } }
  @keyframes course-dashboard-float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-6px); } }
  @keyframes course-card-float { 0%,100% { transform:translateY(0); } 50% { transform:translateY(-5px); } }
  @media(max-width:1100px) { .course-hero__listing-grid { grid-template-columns:minmax(0,1fr) minmax(300px,.72fr); gap:2.5rem; }.course-hero__dashboard{border-radius:25px}.course-hero__floating{right:0} }
  @media(max-width:900px) { .course-hero__listing-grid,.course-hero__detail-grid { grid-template-columns:1fr; }.course-hero__visual{width:min(100%,560px);min-height:420px;margin:1rem auto 0}.course-hero__cover{min-height:330px}.course-hero__facts{grid-template-columns:repeat(2,1fr)} }
  @media(max-width:480px) { .course-hero__visual{min-height:auto;padding:1rem 0 0;place-items:stretch}.course-hero__dashboard{width:100%;padding:1rem;border-radius:22px}.course-hero__dashboard-topline{align-items:flex-start}.course-hero__lesson-count{padding:.3rem .45rem}.course-hero__step{gap:.6rem;padding:.65rem}.course-hero__floating{position:relative;right:auto;bottom:auto;justify-self:end;margin:-.45rem .6rem 0 0}.course-hero__facts{grid-template-columns:1fr}.course-hero__cover{min-height:290px}.course-hero__cover-overlay{padding:1.4rem} }
  @media(prefers-reduced-motion:reduce) { .course-hero__visual,.course-hero__dashboard,.course-hero__floating { animation:none; } }
</style>

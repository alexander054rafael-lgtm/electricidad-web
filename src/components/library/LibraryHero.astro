---
import { BookOpen, Zap } from '@lucide/astro';
---

<section class="library-hero">
  <div class="library-hero__orb library-hero__orb--one" aria-hidden="true"></div>
  <div class="library-hero__orb library-hero__orb--two" aria-hidden="true"></div>
  <div class="container library-hero__inner">
    <div>
      <span class="library-hero__eyebrow"><Zap size={15} /> Recursos técnicos seleccionados</span>
      <h1>Biblioteca <span>Técnica</span></h1>
      <p>Explora libros, manuales, guías y documentos técnicos de electricidad industrial y automatización.</p>
    </div>
    <div class="library-hero__visual" aria-hidden="true">
      <BookOpen size={68} stroke-width={1.25} />
      <span class="library-hero__line"></span><span class="library-hero__line"></span><span class="library-hero__line"></span>
      <div class="library-hero__bolt">⚡</div>
    </div>
  </div>
</section>

<style>
  .library-hero { position: relative; isolation: isolate; overflow: hidden; padding: clamp(8rem, 13vw, 11rem) 0 clamp(3.5rem, 7vw, 5rem); background: linear-gradient(135deg, #f0fdf4, #fff 55%, #ecfdf5); }
  .library-hero__inner { display: grid; grid-template-columns: 1fr; align-items: center; gap: 2rem; position: relative; z-index: 1; }
  @media (min-width: 760px) { .library-hero__inner { grid-template-columns: 1.4fr .6fr; } }
  .library-hero__eyebrow { display: inline-flex; align-items: center; gap: .45rem; padding: .4rem .8rem; border: 1px solid rgba(22,163,74,.18); border-radius: 999px; color: var(--color-primary-dark); background: rgba(255,255,255,.7); font-size: .8rem; font-weight: 700; }
  h1 { margin: 1rem 0; font-size: clamp(2.65rem, 6vw, 4.8rem); font-weight: 800; letter-spacing: -.055em; }
  h1 span { color: var(--color-primary); }
  p { max-width: 650px; font-size: clamp(1rem, 2vw, 1.18rem); color: var(--color-text-secondary); }
  .library-hero__visual { position: relative; place-self: center; display: grid; place-items: center; width: 180px; aspect-ratio: 1; border: 1px solid rgba(22,163,74,.16); border-radius: 30px; color: var(--color-primary-dark); background: rgba(255,255,255,.72); box-shadow: 0 20px 50px rgba(20,83,45,.12); transform: rotate(4deg); }
  .library-hero__line { width: 72px; height: 3px; margin: 3px; border-radius: 999px; background: rgba(22,163,74,.25); }
  .library-hero__bolt { position: absolute; top: -14px; right: -14px; display: grid; place-items: center; width: 44px; height: 44px; border-radius: 14px; background: #14532d; color: white; box-shadow: 0 8px 22px rgba(20,83,45,.25); transform: rotate(-10deg); }
  .library-hero__orb { position: absolute; z-index: -1; border-radius: 50%; filter: blur(12px); background: rgba(34,197,94,.12); }
  .library-hero__orb--one { width: 280px; height: 280px; top: -100px; right: 8%; }.library-hero__orb--two { width: 190px; height: 190px; bottom: -80px; left: 20%; }
</style>

---
import type { Book } from '../../data/books';
import BookGrid from './BookGrid.astro';
interface Props { books: Book[] }
const { books } = Astro.props;
---
{books.length > 0 && <section class="related-books"><h2>Libros relacionados</h2><BookGrid books={books} /></section>}
<style>.related-books{margin-top:4rem;padding-top:3rem;border-top:1px solid var(--color-border)}.related-books>h2{margin-bottom:1.5rem;font-size:1.6rem}</style>

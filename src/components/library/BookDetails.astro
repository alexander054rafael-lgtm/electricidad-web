---
import { BookOpen, Calendar, Download, FileText, Languages, UserRound } from '@lucide/astro';
import type { Book } from '../../data/books';
import PdfViewer from './PdfViewer.astro';
interface Props { book: Book }
const { book } = Astro.props;
---
<section class="book-details"><div class="book-details__cover" style={`--accent:${book.accent}`}><span>{book.type}</span><BookOpen size={72} stroke-width={1.1}/><strong>{book.title}</strong><small>Biblioteca técnica · InduTech</small></div><div class="book-details__content"><p class="book-details__category">{book.category}</p><h1>{book.title}</h1><p class="book-details__author"><UserRound size={17}/> {book.author}</p><p class="book-details__description">{book.description} Este contenido de demostración está pensado para ser reemplazado por documentación propia, autorizada o de dominio público.</p><dl class="book-details__facts"><div><dt><FileText size={16}/> Documento</dt><dd>{book.pages} páginas · {book.fileSize}</dd></div><div><dt><Languages size={16}/> Idioma y nivel</dt><dd>{book.language} · {book.level}</dd></div><div><dt><Calendar size={16}/> Publicación</dt><dd>{book.publicationYear} · {book.downloads.toLocaleString('es')} descargas</dd></div></dl><div class="book-details__actions"><a href="#visor" class="book-details__read"><BookOpen size={18}/> Leer ahora</a><a href={book.pdfUrl} target="_blank" rel="noopener" class="book-details__download"><Download size={18}/> Descargar PDF</a></div></div></section><section class="book-topics"><h2>Temas incluidos</h2><ul>{book.topics.map(topic => <li>{topic}</li>)}</ul></section><div id="visor"><PdfViewer src={book.pdfUrl} title={book.title}/></div>
<style>
.book-details{display:grid;grid-template-columns:1fr;gap:2rem;padding-top:calc(var(--header-height) + 3rem)}@media(min-width:800px){.book-details{grid-template-columns:310px 1fr;gap:3.5rem}}.book-details__cover{display:flex;position:relative;flex-direction:column;justify-content:flex-end;min-height:410px;padding:2rem;border-radius:24px;overflow:hidden;color:#fff;background:linear-gradient(150deg,color-mix(in srgb,var(--accent),#0f172a 10%),#0f172a);box-shadow:var(--shadow-xl)}.book-details__cover:before{content:'';position:absolute;width:280px;aspect-ratio:1;top:-105px;right:-100px;border:1px solid rgba(255,255,255,.18);border-radius:50%;box-shadow:0 0 0 32px rgba(255,255,255,.04),0 0 0 64px rgba(255,255,255,.03)}.book-details__cover span{position:absolute;top:1.35rem;left:1.35rem;padding:.3rem .65rem;border-radius:999px;background:rgba(255,255,255,.15);font-size:.75rem;font-weight:800;text-transform:uppercase}.book-details__cover svg{position:absolute;right:1.5rem;bottom:1.2rem;opacity:.2}.book-details__cover strong{font:800 1.65rem/1.12 var(--font-display);max-width:85%;z-index:1}.book-details__cover small{margin-top:.6rem;opacity:.7}.book-details__category{color:var(--color-primary);font-size:.84rem;font-weight:800}.book-details h1{margin:.45rem 0 1rem;font-size:clamp(2rem,4vw,3.25rem)}.book-details__author{display:flex;align-items:center;gap:.45rem;color:var(--color-text-secondary)}.book-details__description{max-width:720px;margin:1.4rem 0;color:var(--color-text-secondary);line-height:1.75}.book-details__facts{display:grid;gap:.65rem;margin:1.5rem 0}.book-details__facts div{padding:.7rem 0;border-bottom:1px solid var(--color-border)}.book-details dt{display:flex;align-items:center;gap:.4rem;color:var(--color-text-secondary);font-size:.78rem;font-weight:700}.book-details dd{margin:.2rem 0 0;font-weight:700}.book-details__actions{display:flex;flex-wrap:wrap;gap:.7rem}.book-details__actions a{display:inline-flex;align-items:center;gap:.5rem;padding:.8rem 1.1rem;border-radius:12px;font-weight:700}.book-details__read{color:#fff;background:var(--color-primary)}.book-details__download{color:var(--color-primary);border:1px solid var(--color-primary)}.book-topics{margin-top:3rem;padding:1.5rem;border:1px solid var(--color-border);border-radius:var(--radius-lg);background:var(--color-gray-50)}.book-topics h2{font-size:1.15rem}.book-topics ul{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:.65rem;margin-top:1rem}.book-topics li:before{content:'✓';margin-right:.5rem;color:var(--color-primary);font-weight:800}
</style>

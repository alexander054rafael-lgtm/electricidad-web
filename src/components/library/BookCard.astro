---
import { BookOpen, Download, Heart, FileText, Languages } from '@lucide/astro';
import type { Book } from '../../data/books';
interface Props { book: Book }
const { book } = Astro.props;
---
<article class="book-card" data-book data-search={`${book.title} ${book.author} ${book.category} ${book.tags.join(' ')}`.toLowerCase()} data-category={book.category} data-level={book.level} data-type={book.type} data-language={book.language} data-year={book.publicationYear} data-downloads={book.downloads}>
  <a href={`/biblioteca/${book.slug}`} class="book-card__cover" style={`--accent:${book.accent}`} aria-label={`Ver ${book.title}`}>
    <span class="book-card__cover-type">{book.type}</span><BookOpen size={44} stroke-width={1.2} /><strong>{book.title}</strong><small>InduTech · Biblioteca técnica</small>
  </a>
  <div class="book-card__body">
    <div class="book-card__meta"><span>{book.category}</span>{book.badge && <b>{book.badge}</b>}</div>
    <h2><a href={`/biblioteca/${book.slug}`}>{book.title}</a></h2><p class="book-card__author">{book.author}</p><p class="book-card__description">{book.description}</p>
    <div class="book-card__details"><span><FileText size={14}/> {book.pages} págs.</span><span><Languages size={14}/> {book.language}</span><span>{book.level}</span></div>
    <div class="book-card__actions"><a href={`/biblioteca/${book.slug}`} class="book-card__read"><BookOpen size={16}/> Leer PDF</a>{book.allowDownload && <a href={book.pdfUrl} download class="book-card__download" aria-label={`Descargar ${book.title}`}><Download size={17}/></a>}<button type="button" class="book-card__favorite" aria-label={`Guardar ${book.title} en favoritos`}><Heart size={17}/></button></div>
  </div>
</article>
<style>
  .book-card { display:flex; flex-direction:column; overflow:hidden; background:var(--color-surface); border:1px solid var(--color-border); border-radius:var(--radius-xl); box-shadow:var(--shadow-sm); transition:transform var(--transition-base),box-shadow var(--transition-base); }.book-card:hover { transform:translateY(-6px); box-shadow:var(--shadow-xl); }.book-card__cover { position:relative; display:flex; flex-direction:column; justify-content:flex-end; min-height:230px; overflow:hidden; padding:1.35rem; color:white; background:linear-gradient(150deg,color-mix(in srgb,var(--accent),#0f172a 15%),#0f172a); isolation:isolate; }.book-card__cover:before { content:''; position:absolute; width:180px; aspect-ratio:1; top:-52px; right:-48px; z-index:-1; border:1px solid rgba(255,255,255,.2); border-radius:50%; box-shadow:0 0 0 24px rgba(255,255,255,.04),0 0 0 48px rgba(255,255,255,.03); transition:transform var(--transition-slow); }.book-card:hover .book-card__cover:before { transform:scale(1.15); }.book-card__cover svg { position:absolute; right:1.15rem; bottom:1.1rem; opacity:.22; }.book-card__cover-type { position:absolute; top:1rem; left:1rem; padding:.25rem .55rem; border-radius:999px; background:rgba(255,255,255,.16); font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.06em; }.book-card__cover strong { max-width:80%; font-family:var(--font-display); font-size:1.2rem; line-height:1.16; }.book-card__cover small { margin-top:.55rem; opacity:.72; font-size:.68rem; }.book-card__body { display:flex; flex:1; flex-direction:column; padding:1.25rem; }.book-card__meta { display:flex; justify-content:space-between; gap:.5rem; color:var(--color-primary); font-size:.73rem; font-weight:700; }.book-card__meta b { padding:.15rem .45rem; border-radius:999px; background:rgba(22,163,74,.1); }.book-card h2 { margin:.65rem 0 .2rem; font-size:1.08rem; line-height:1.3; }.book-card__author { color:var(--color-text-secondary); font-size:.82rem; }.book-card__description { margin:.85rem 0; color:var(--color-text-secondary); font-size:.84rem; line-height:1.55; }.book-card__details { display:flex; flex-wrap:wrap; gap:.55rem .8rem; margin-top:auto; color:var(--color-text-secondary); font-size:.74rem; }.book-card__details span { display:inline-flex; align-items:center; gap:.25rem; }.book-card__actions { display:flex; gap:.5rem; margin-top:1.1rem; }.book-card__read,.book-card__download,.book-card__favorite { display:inline-flex; align-items:center; justify-content:center; gap:.35rem; min-height:36px; border-radius:10px; font:inherit; font-size:.8rem; font-weight:700; }.book-card__read { flex:1; color:white; background:var(--color-primary); }.book-card__download,.book-card__favorite { width:36px; color:var(--color-primary); border:1px solid var(--color-border); background:transparent; }
</style>

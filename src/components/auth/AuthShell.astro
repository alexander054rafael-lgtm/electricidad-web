---
import Layout from '../../layouts/Layout.astro';
import Header from '../landing/Header.astro';
import Footer from '../landing/Footer.astro';
interface Props { title: string; description: string; eyebrow: string }
const { title, description, eyebrow } = Astro.props;
---

<Layout title={`${title} | InduTech Academy`} description={description}>
  <Header />
  <main class="auth-page"><section class="auth-card"><div class="auth-card__intro"><span>{eyebrow}</span><h1>{title}</h1><p>{description}</p></div><slot /></section></main>
  <Footer />
</Layout>

<style>
  .auth-page{display:grid;min-height:80vh;place-items:center;padding:calc(var(--header-height) + 3rem) 1rem 5rem;background:radial-gradient(circle at 80% 15%,rgba(34,197,94,.14),transparent 32%),var(--color-gray-50)}
  .auth-card{width:100%;max-width:560px;padding:clamp(1.3rem,5vw,2.5rem);border:1px solid var(--color-border);border-radius:var(--radius-2xl);background:var(--color-surface);box-shadow:var(--shadow-xl)}.auth-card__intro>span{color:var(--color-primary);font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em}.auth-card h1{margin:.4rem 0 .65rem;font-size:clamp(2rem,5vw,3rem)}.auth-card__intro>p{color:var(--color-text-secondary);font-size:.88rem;line-height:1.65}
</style>

<style is:global>
  .auth-form{display:grid;gap:1rem;margin-top:1.6rem}.auth-form__row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.auth-form label{display:grid;gap:.4rem;color:var(--color-text);font-size:.76rem;font-weight:750}.auth-form input{width:100%;padding:.8rem .9rem;border:1px solid #cbd5e1;border-radius:12px;background-color:#ffffff;color:#0f172a;-webkit-text-fill-color:#0f172a;caret-color:#16a34a;opacity:1;color-scheme:light;font:inherit}.auth-form input[type="password"]{color:#0f172a;-webkit-text-fill-color:#0f172a;opacity:1}.auth-form input::placeholder{color:#94a3b8;-webkit-text-fill-color:#94a3b8;opacity:1}.auth-form input:-webkit-autofill,.auth-form input:-webkit-autofill:hover,.auth-form input:-webkit-autofill:focus,.auth-form input:-webkit-autofill:active{-webkit-text-fill-color:#0f172a !important;-webkit-box-shadow:0 0 0 1000px #ffffff inset !important;box-shadow:0 0 0 1000px #ffffff inset !important;caret-color:#16a34a}.auth-form input:focus{border-color:#22c55e;box-shadow:0 0 0 3px rgba(34,197,94,.15);outline:none}.auth-form button{min-height:48px;margin-top:.25rem;padding:.75rem 1rem;border-radius:999px;background:var(--color-primary);color:#fff;font-size:.8rem;font-weight:800;box-shadow:0 7px 20px rgba(22,163,74,.2)}.auth-form__links{display:flex;flex-wrap:wrap;justify-content:space-between;gap:.5rem;margin-top:1.1rem;color:var(--color-text-secondary);font-size:.74rem}.auth-form__links a{color:var(--color-primary);font-weight:750}.auth-message{margin-top:1.2rem;padding:.85rem 1rem;border-radius:12px;font-size:.78rem;line-height:1.55}.auth-message--error{background:rgba(220,38,38,.08);color:#b91c1c}.auth-message--success{background:rgba(22,163,74,.1);color:var(--color-primary-dark)}
  @media(max-width:520px){.auth-form__row{grid-template-columns:1fr}}
</style>

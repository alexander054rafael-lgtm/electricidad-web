---
import Layout from '../../layouts/Layout.astro';
import Header from '../landing/Header.astro';
import Footer from '../landing/Footer.astro';
interface Props { title: string; description: string; eyebrow: string }
const { title, description, eyebrow } = Astro.props;
---

<Layout title={`${title} | InduTech Academy`} description={description}>
  <Header />
  <main class="auth-page"><section class="auth-card"><div class="auth-card__intro"><span>{eyebrow}</span><h1>{title}</h1><p>{description}</p></div><slot /></section></main>
  <Footer />
</Layout>

<style>
  .auth-page{display:grid;min-height:80vh;place-items:center;padding:calc(var(--header-height) + 3rem) 1rem 5rem;background:radial-gradient(circle at 80% 15%,rgba(34,197,94,.14),transparent 32%),var(--color-gray-50)}
  .auth-card{width:100%;max-width:560px;padding:clamp(1.3rem,5vw,2.5rem);border:1px solid var(--color-border);border-radius:var(--radius-2xl);background:var(--color-surface);box-shadow:var(--shadow-xl)}.auth-card__intro>span{color:var(--color-primary);font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em}.auth-card h1{margin:.4rem 0 .65rem;font-size:clamp(2rem,5vw,3rem)}.auth-card__intro>p{color:var(--color-text-secondary);font-size:.88rem;line-height:1.65}
</style>

<style is:global>
  .auth-form{display:grid;gap:1rem;margin-top:1.6rem}.auth-form__row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}.auth-form__field{display:grid;gap:.4rem}.auth-form label{display:grid;gap:.4rem;color:var(--color-text);font-size:.76rem;font-weight:750}.auth-form input{width:100%;padding:.8rem .9rem;border:1px solid #cbd5e1;border-radius:12px;background-color:#ffffff;color:#0f172a;-webkit-text-fill-color:#0f172a;caret-color:#16a34a;opacity:1;color-scheme:light;font:inherit}.auth-form input[type="password"]{color:#0f172a;-webkit-text-fill-color:#0f172a;opacity:1}.auth-form input::placeholder{color:#94a3b8;-webkit-text-fill-color:#94a3b8;opacity:1}.auth-form input:-webkit-autofill,.auth-form input:-webkit-autofill:hover,.auth-form input:-webkit-autofill:focus,.auth-form input:-webkit-autofill:active{-webkit-text-fill-color:#0f172a !important;-webkit-box-shadow:0 0 0 1000px #ffffff inset !important;box-shadow:0 0 0 1000px #ffffff inset !important;caret-color:#16a34a}.auth-form input:focus{border-color:#22c55e;box-shadow:0 0 0 3px rgba(34,197,94,.15);outline:none}.auth-form>button{min-height:48px;margin-top:.25rem;padding:.75rem 1rem;border-radius:999px;background:var(--color-primary);color:#fff;font-size:.8rem;font-weight:800;box-shadow:0 7px 20px rgba(22,163,74,.2)}.auth-form__links{display:flex;flex-wrap:wrap;justify-content:space-between;gap:.5rem;margin-top:1.1rem;color:var(--color-text-secondary);font-size:.74rem}.auth-form__links a{color:var(--color-primary);font-weight:750}.auth-message{margin-top:1.2rem;padding:.85rem 1rem;border-radius:12px;font-size:.78rem;line-height:1.55}.auth-message--error{background:rgba(220,38,38,.08);color:#b91c1c}.auth-message--success{background:rgba(22,163,74,.1);color:var(--color-primary-dark)}

  .password-field{position:relative;min-width:0}
  .password-field input{width:100%;padding-right:3.75rem}
  .password-toggle{position:absolute;z-index:1;top:50%;right:.55rem;transform:translateY(-50%);width:2.35rem;height:2.35rem;display:grid;place-items:center;padding:0;border-radius:.8rem;border:1px solid rgba(15,23,42,.08);background:linear-gradient(145deg,rgba(255,255,255,.96),rgba(241,245,249,.9));color:#64748b;box-shadow:0 4px 12px rgba(15,23,42,.08),inset 0 1px 0 rgba(255,255,255,.9);cursor:pointer;transition:color 180ms ease,border-color 180ms ease,background 180ms ease,box-shadow 180ms ease,transform 180ms ease}
  .password-toggle:hover{color:#15803d;border-color:rgba(34,197,94,.35);background:linear-gradient(145deg,rgba(240,253,244,.98),rgba(220,252,231,.9));box-shadow:0 6px 16px rgba(22,163,74,.13),inset 0 1px 0 rgba(255,255,255,.95);transform:translateY(-50%) scale(1.04)}
  .password-toggle:active{transform:translateY(-50%) scale(.96)}
  .password-toggle:focus-visible{outline:2px solid #22c55e;outline-offset:2px;color:#15803d}
  .password-toggle[aria-pressed="true"]{color:#15803d;border-color:rgba(34,197,94,.35);background:rgba(220,252,231,.92);box-shadow:0 5px 14px rgba(22,163,74,.12),inset 0 1px 0 rgba(255,255,255,.9)}
  .password-toggle__icon{position:absolute;width:19px;height:19px;opacity:0;transform:scale(.75);pointer-events:none;transition:opacity 160ms ease,transform 160ms ease}
  .password-toggle[aria-pressed="false"] .password-toggle__icon--show,.password-toggle[aria-pressed="true"] .password-toggle__icon--hide{opacity:1;transform:scale(1)}

  @media(max-width:520px){.auth-form__row{grid-template-columns:1fr}.password-toggle{width:2.5rem;height:2.5rem}}
  @media(max-width:380px){.password-toggle{right:.4rem}}
  @media(prefers-reduced-motion:reduce){.password-toggle,.password-toggle__icon{transition:none}.password-toggle:hover,.password-toggle:active{transform:translateY(-50%)}.password-toggle[aria-pressed] .password-toggle__icon{transform:none}}
</style>

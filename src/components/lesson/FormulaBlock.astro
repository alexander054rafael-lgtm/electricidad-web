---
import { Calculator } from '@lucide/astro';
import type { FormulaBlockData } from '../../data/lessons';
interface Props { block: FormulaBlockData }
const { block } = Astro.props;
---

<section class="formula-block" aria-label={block.label ?? 'Fórmula'}>
  <div class="formula-block__label"><Calculator size={18} aria-hidden="true" /> {block.label ?? 'Fórmula'}</div>
  <p>{block.content}</p>
  {block.variables && (
    <dl>{block.variables.map((variable) => <div><dt>{variable.symbol}</dt><dd>{variable.meaning}{variable.unit && <small>{variable.unit}</small>}</dd></div>)}</dl>
  )}
</section>

<style>
  .formula-block{margin:1.75rem 0;padding:clamp(1.25rem,3vw,2rem);border:1px solid rgba(22,163,74,.22);border-radius:var(--radius-xl);background:linear-gradient(135deg,rgba(22,163,74,.08),var(--color-surface));box-shadow:var(--shadow-sm)}
  .formula-block__label{display:flex;align-items:center;gap:.45rem;color:var(--color-primary);font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.07em}
  p{margin:1rem 0;font:700 clamp(1.6rem,5vw,2.8rem)/1.2 var(--font-display);letter-spacing:.02em;text-align:center;color:var(--color-text)}
  dl{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:.65rem;margin-top:1.25rem}dl div{display:flex;align-items:center;gap:.65rem;padding:.7rem;border:1px solid var(--color-border);border-radius:12px;background:var(--color-surface)}dt{display:grid;place-items:center;min-width:36px;height:36px;border-radius:9px;background:rgba(22,163,74,.1);color:var(--color-primary-dark);font:800 1rem var(--font-display)}dd{display:grid;color:var(--color-text-secondary);font-size:.76rem}dd small{color:var(--color-primary);font-weight:700}
</style>

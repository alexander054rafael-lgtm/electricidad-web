---
import Container from '../ui/Container.astro';
import SectionHeading from '../ui/SectionHeading.astro';
import { ArrowUpRight } from '@lucide/astro';

const categories = [
  {
    title: 'PLC',
    description: 'Programación Siemens, Allen-Bradley y más',
    gradient: 'linear-gradient(135deg, #14532d 0%, #16a34a 100%)',
    icon: '⚙',
  },
  {
    title: 'Variadores',
    description: 'Control de velocidad y eficiencia energética',
    gradient: 'linear-gradient(135deg, #1e3a2f 0%, #22c55e 100%)',
    icon: '📈',
  },
  {
    title: 'Electricidad Industrial',
    description: 'Tableros, motores y protecciones',
    gradient: 'linear-gradient(135deg, #0f172a 0%, #334155 100%)',
    icon: '⚡',
  },
  {
    title: 'Instrumentación',
    description: 'Sensores, transmisores y calibración',
    gradient: 'linear-gradient(135deg, #164e3b 0%, #059669 100%)',
    icon: '📊',
  },
  {
    title: 'Automatización',
    description: 'SCADA, HMI y control de procesos',
    gradient: 'linear-gradient(135deg, #14532d 0%, #0d9488 100%)',
    icon: '🏭',
  },
  {
    title: 'Electrónica',
    description: 'Circuitos, semiconductores y potencia',
    gradient: 'linear-gradient(135deg, #1e293b 0%, #16a34a 100%)',
    icon: '💡',
  },
];
---

<section class="categories" id="categorias">
  <Container>
    <div class="reveal">
      <SectionHeading
        eyebrow="Especialidades"
        title="Explora nuestras áreas de formación"
        subtitle="Categorías diseñadas para cubrir cada aspecto de la ingeniería industrial moderna."
      />
    </div>

    <div class="categories__grid">
      {categories.map((cat, i) => (
        <a
          href="#cursos"
          class:list={['categories__card', 'reveal', `reveal-delay-${(i % 3) + 1}`]}
          style={`--card-gradient: ${cat.gradient}`}
        >
          <div class="categories__card-bg" aria-hidden="true">
            <span class="categories__card-icon">{cat.icon}</span>
          </div>
          <div class="categories__card-content">
            <h3 class="categories__card-title">{cat.title}</h3>
            <p class="categories__card-desc">{cat.description}</p>
            <span class="categories__card-link">
              Ver cursos
              <ArrowUpRight size={16} stroke-width={2.5} />
            </span>
          </div>
        </a>
      ))}
    </div>
  </Container>
</section>

<style>
  .categories {
    padding-block: clamp(5rem, 10vw, 8rem);
  }

  .categories__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .categories__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .categories__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.75rem;
    }
  }

  .categories__card {
    position: relative;
    display: block;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    transition:
      transform var(--transition-base),
      box-shadow var(--transition-base);
    min-height: 280px;
  }

  .categories__card:hover {
    transform: translateY(-6px) scale(1.01);
    box-shadow: var(--shadow-xl);
  }

  .categories__card-bg {
    position: absolute;
    inset: 0;
    background: var(--card-gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--transition-slow);
  }

  .categories__card:hover .categories__card-bg {
    transform: scale(1.08);
  }

  .categories__card-icon {
    font-size: 4rem;
    opacity: 0.25;
    filter: grayscale(0.3);
    transition: opacity var(--transition-base), transform var(--transition-base);
  }

  .categories__card:hover .categories__card-icon {
    opacity: 0.35;
    transform: scale(1.1);
  }

  .categories__card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    height: 100%;
    min-height: 280px;
    padding: 1.75rem;
    background: linear-gradient(to top, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0.3) 60%, transparent 100%);
    color: white;
  }

  .categories__card-title {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.375rem;
    color: white;
  }

  .categories__card-desc {
    font-size: 0.875rem;
    opacity: 0.8;
    margin-bottom: 1rem;
    line-height: 1.5;
  }

  .categories__card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 600;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity var(--transition-base),
      transform var(--transition-base);
  }

  .categories__card:hover .categories__card-link {
    opacity: 1;
    transform: translateY(0);
  }
</style>

---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class:list={['bg-pattern', className]} aria-hidden="true">
  <div class="bg-pattern__gradient"></div>
  <svg class="bg-pattern__grid" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(22,163,74,0.06)" stroke-width="0.5"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#grid)"/>
  </svg>
  <svg class="bg-pattern__circuit" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
    <circle cx="400" cy="400" r="300" fill="none" stroke="rgba(22,163,74,0.04)" stroke-width="1"/>
    <circle cx="400" cy="400" r="200" fill="none" stroke="rgba(22,163,74,0.05)" stroke-width="1"/>
    <circle cx="400" cy="400" r="100" fill="none" stroke="rgba(22,163,74,0.06)" stroke-width="1"/>
    <line x1="400" y1="100" x2="400" y2="700" stroke="rgba(22,163,74,0.04)" stroke-width="1"/>
    <line x1="100" y1="400" x2="700" y2="400" stroke="rgba(22,163,74,0.04)" stroke-width="1"/>
  </svg>
  <div class="bg-pattern__dots">
    {Array.from({ length: 12 }).map((_, i) => (
      <span class="bg-pattern__dot" style={`--i: ${i}`}></span>
    ))}
  </div>
</div>

<style>
  .bg-pattern {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .bg-pattern__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 20%, var(--color-gradient-start) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 80%, var(--color-gradient-end) 0%, transparent 60%);
  }

  .bg-pattern__grid {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.6;
  }

  .bg-pattern__circuit {
    position: absolute;
    top: 50%;
    right: -10%;
    width: min(70vw, 700px);
    height: min(70vw, 700px);
    transform: translateY(-50%);
    opacity: 0.5;
    animation: circuit-rotate 120s linear infinite;
  }

  .bg-pattern__dots {
    position: absolute;
    inset: 0;
  }

  .bg-pattern__dot {
    position: absolute;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-primary);
    opacity: 0.15;
    animation: dot-float 6s ease-in-out infinite;
    animation-delay: calc(var(--i) * 0.5s);
  }

  .bg-pattern__dot:nth-child(1)  { top: 15%; left: 10%; }
  .bg-pattern__dot:nth-child(2)  { top: 25%; left: 85%; }
  .bg-pattern__dot:nth-child(3)  { top: 45%; left: 5%; }
  .bg-pattern__dot:nth-child(4)  { top: 60%; left: 92%; }
  .bg-pattern__dot:nth-child(5)  { top: 75%; left: 15%; }
  .bg-pattern__dot:nth-child(6)  { top: 85%; left: 70%; }
  .bg-pattern__dot:nth-child(7)  { top: 10%; left: 50%; }
  .bg-pattern__dot:nth-child(8)  { top: 35%; left: 75%; }
  .bg-pattern__dot:nth-child(9)  { top: 55%; left: 40%; }
  .bg-pattern__dot:nth-child(10) { top: 70%; left: 55%; }
  .bg-pattern__dot:nth-child(11) { top: 90%; left: 35%; }
  .bg-pattern__dot:nth-child(12) { top: 5%;  left: 30%; }

  @keyframes circuit-rotate {
    from { transform: translateY(-50%) rotate(0deg); }
    to   { transform: translateY(-50%) rotate(360deg); }
  }

  @keyframes dot-float {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.15; }
    50%      { transform: translateY(-8px) scale(1.3); opacity: 0.3; }
  }
</style>

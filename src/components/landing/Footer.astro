---
import Container from '../ui/Container.astro';
import { ArrowRight, Camera, Mail, Play, Send, Share2 } from '@lucide/astro';

const quickLinks = [
  { label: 'Cursos', href: '/cursos' },
  { label: 'Juegos', href: '/juegos' },
  { label: 'Blog', href: '#blog' },
  { label: 'Ebooks', href: '#ebook' },
  { label: 'Recursos', href: '#recursos' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const legalLinks = [
  { label: 'Términos de uso', href: '#' },
  { label: 'Política de privacidad', href: '#' },
  { label: 'Cookies', href: '#' },
];

const socials = [
  { icon: Share2, href: '#', label: 'LinkedIn' },
  { icon: Play, href: '#', label: 'YouTube' },
  { icon: Camera, href: '#', label: 'Instagram' },
  { icon: Mail, href: '#', label: 'Email' },
];
---

<footer class="footer">
  <div class="footer__glow" aria-hidden="true"></div>
  <Container>
    <section class="footer__newsletter" aria-labelledby="footer-newsletter-title">
      <div class="footer__newsletter-copy">
        <span class="footer__eyebrow">Conocimiento que impulsa tu carrera</span>
        <h2 id="footer-newsletter-title">Aprende algo útil cada semana.</h2>
        <p>Tips técnicos, novedades y recursos gratuitos para crecer en la industria.</p>
      </div>
      <div class="footer__newsletter-action">
        <form class="footer__form" action="#" method="post">
          <label for="newsletter-email" class="sr-only">Correo electrónico</label>
          <div class="footer__input-wrap">
            <Mail size={18} stroke-width={1.8} aria-hidden="true" />
            <input
              type="email"
              id="newsletter-email"
              name="email"
              placeholder="tu@email.com"
              required
              autocomplete="email"
              class="footer__input"
            />
          </div>
          <button type="submit" class="footer__submit">
            <span>Suscribirme</span>
            <Send size={17} stroke-width={2} aria-hidden="true" />
          </button>
        </form>
        <small>Sin spam. Puedes cancelar cuando quieras.</small>
      </div>
    </section>

    <div class="footer__main">
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label="Ir al inicio de InduTech Academy">
          <svg width="42" height="42" viewBox="0 0 42 42" fill="none" aria-hidden="true">
            <rect x="0.5" y="0.5" width="41" height="41" rx="12" fill="url(#footerLogoGrad)" stroke="rgba(255,255,255,.16)"/>
            <path d="M21 9.5L27 21H15L21 9.5Z" fill="white" opacity="0.96"/>
            <rect x="13" y="25" width="16" height="2.8" rx="1.4" fill="white" opacity="0.8"/>
            <defs>
              <linearGradient id="footerLogoGrad" x1="3" y1="2" x2="39" y2="40">
                <stop stop-color="#22c55e"/>
                <stop offset="1" stop-color="#15803d"/>
              </linearGradient>
            </defs>
          </svg>
          <span><strong>InduTech</strong><small>Academy</small></span>
        </a>
        <p class="footer__desc">
          La plataforma líder en formación de electricidad industrial, automatización y control de procesos. Formando a la próxima generación de ingenieros.
        </p>
        <div class="footer__socials">
          {socials.map((social) => {
            const Icon = social.icon;
            return (
              <a href={social.href} class="footer__social" aria-label={social.label}>
                <Icon size={18} stroke-width={1.9} />
              </a>
            );
          })}
        </div>
      </div>

      <div class="footer__links-group">
        <h3 class="footer__heading">Enlaces rápidos</h3>
        <ul>
          {quickLinks.map((link) => (
            <li><a href={link.href} class="footer__link"><span>{link.label}</span><ArrowRight size={14} aria-hidden="true" /></a></li>
          ))}
        </ul>
      </div>

      <div class="footer__links-group">
        <h3 class="footer__heading">Legal</h3>
        <ul>
          {legalLinks.map((link) => (
            <li><a href={link.href} class="footer__link"><span>{link.label}</span><ArrowRight size={14} aria-hidden="true" /></a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {new Date().getFullYear()} InduTech Academy. Todos los derechos reservados.</p>
      <p class="footer__signature"><span aria-hidden="true"></span> Formación técnica para el mundo real</p>
    </div>
  </Container>
</footer>

<style>
  .footer {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    padding-block: clamp(3.5rem, 7vw, 6rem) 1.75rem;
    border-top: 1px solid rgba(34, 197, 94, 0.45);
    background:
      radial-gradient(circle at 12% 5%, rgba(34, 197, 94, 0.1), transparent 28rem),
      radial-gradient(circle at 88% 38%, rgba(14, 165, 233, 0.07), transparent 30rem),
      linear-gradient(180deg, #0b1220 0%, #070d18 100%);
    color: #aeb9c9;
  }

  .footer::before {
    position: absolute;
    z-index: 1;
    top: -1px;
    right: 0;
    left: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent 4%, #22c55e 48%, rgba(56, 189, 248, 0.65) 68%, transparent 96%);
    box-shadow: 0 0 26px rgba(34, 197, 94, 0.42);
    content: '';
  }

  .footer::after {
    position: absolute;
    z-index: -1;
    inset: 0;
    opacity: 0.22;
    background-image: linear-gradient(rgba(255,255,255,.025) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.025) 1px, transparent 1px);
    background-size: 44px 44px;
    mask-image: linear-gradient(to bottom, black, transparent 72%);
    content: '';
  }

  .footer__glow {
    position: absolute;
    z-index: -1;
    top: -11rem;
    left: 50%;
    width: min(70vw, 760px);
    height: 18rem;
    border-radius: 50%;
    background: rgba(34, 197, 94, 0.09);
    filter: blur(80px);
    transform: translateX(-50%);
    pointer-events: none;
  }

  .footer__newsletter {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, .95fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
    margin-bottom: clamp(3.5rem, 7vw, 5.5rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 24px;
    background: linear-gradient(135deg, rgba(255,255,255,.065), rgba(255,255,255,.025));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.06), 0 24px 70px rgba(0,0,0,.2);
    backdrop-filter: blur(10px);
  }

  .footer__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    margin-bottom: .8rem;
    color: #4ade80;
    font-size: .7rem;
    font-weight: 800;
    letter-spacing: .11em;
    text-transform: uppercase;
  }

  .footer__eyebrow::before {
    width: 22px;
    height: 1px;
    background: currentColor;
    content: '';
  }

  .footer__newsletter h2 {
    max-width: 560px;
    margin: 0 0 .7rem;
    color: #fff;
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 3vw, 2.4rem);
    line-height: 1.12;
    letter-spacing: -.035em;
  }

  .footer__newsletter-copy p {
    max-width: 560px;
    color: #b7c2d1;
    font-size: .9rem;
    line-height: 1.7;
  }

  .footer__newsletter-action small {
    display: block;
    margin-top: .7rem;
    color: #7f8b9d;
    font-size: .68rem;
  }

  .footer__form {
    display: flex;
    gap: .65rem;
  }

  .footer__input-wrap {
    display: flex;
    flex: 1;
    align-items: center;
    gap: .7rem;
    min-width: 0;
    padding: 0 .95rem;
    border: 1px solid rgba(148, 163, 184, .24);
    border-radius: 12px;
    background: rgba(4, 10, 20, .56);
    color: #738197;
    transition: border-color var(--transition-base), box-shadow var(--transition-base), background var(--transition-base);
  }

  .footer__input-wrap:focus-within {
    border-color: rgba(74, 222, 128, .72);
    background: rgba(4, 10, 20, .8);
    box-shadow: 0 0 0 3px rgba(34, 197, 94, .12);
    color: #4ade80;
  }

  .footer__input {
    width: 100%;
    min-width: 0;
    padding: .82rem 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: #fff;
    font: inherit;
    font-size: .82rem;
  }

  .footer__input::placeholder { color: #718096; }

  .footer__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: .55rem;
    min-height: 46px;
    padding: .72rem 1.15rem;
    border: 1px solid rgba(134, 239, 172, .3);
    border-radius: 12px;
    background: linear-gradient(135deg, #22c55e, #16a34a);
    color: #fff;
    font: inherit;
    font-size: .78rem;
    font-weight: 800;
    box-shadow: 0 9px 24px rgba(22, 163, 74, .23);
    transition: transform var(--transition-fast), box-shadow var(--transition-base), filter var(--transition-base);
  }

  .footer__submit:hover {
    filter: brightness(1.08);
    box-shadow: 0 12px 30px rgba(34, 197, 94, .3);
    transform: translateY(-2px);
  }

  .footer__submit:active { transform: translateY(0); }

  .footer__main {
    display: grid;
    grid-template-columns: minmax(280px, 1.7fr) minmax(150px, .7fr) minmax(150px, .7fr);
    gap: clamp(2.5rem, 8vw, 7rem);
    padding-bottom: clamp(3rem, 6vw, 4.5rem);
  }

  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: .8rem;
    margin-bottom: 1.25rem;
    color: #fff;
    transition: transform var(--transition-base), opacity var(--transition-fast);
  }

  .footer__logo:hover { opacity: .92; transform: translateY(-2px); }

  .footer__logo > span { display: grid; gap: .08rem; }

  .footer__logo strong {
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -.025em;
  }

  .footer__logo small { color: #8fa0b5; font-size: .63rem; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; }

  .footer__desc {
    max-width: 430px;
    margin-bottom: 1.65rem;
    color: #9eacbe;
    font-size: .83rem;
    line-height: 1.78;
  }

  .footer__socials { display: flex; flex-wrap: wrap; gap: .65rem; }

  .footer__social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 39px;
    height: 39px;
    border: 1px solid rgba(148, 163, 184, .16);
    border-radius: 11px;
    background: rgba(255,255,255,.045);
    color: #aeb9c9;
    transition: border-color var(--transition-fast), background var(--transition-fast), color var(--transition-fast), transform var(--transition-fast), box-shadow var(--transition-base);
  }

  .footer__social:hover {
    border-color: rgba(74, 222, 128, .5);
    background: rgba(34, 197, 94, .14);
    color: #4ade80;
    box-shadow: 0 8px 24px rgba(0,0,0,.18);
    transform: translateY(-2px);
  }

  .footer__heading {
    margin-bottom: 1.35rem;
    color: #fff;
    font-size: .78rem;
    font-weight: 800;
    letter-spacing: .04em;
  }

  .footer__links-group ul { display: flex; flex-direction: column; gap: .8rem; }

  .footer__link {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    color: #9eacbe;
    font-size: .8rem;
    transition: color var(--transition-fast), transform var(--transition-fast);
  }

  .footer__link :global(svg) { opacity: 0; transform: translateX(-4px); transition: opacity var(--transition-fast), transform var(--transition-fast); }
  .footer__link:hover { color: #4ade80; transform: translateX(3px); }
  .footer__link:hover :global(svg) { opacity: 1; transform: translateX(0); }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding-top: 1.6rem;
    border-top: 1px solid rgba(148, 163, 184, .13);
    color: #748196;
    font-size: .7rem;
  }

  .footer__signature { display: inline-flex; align-items: center; gap: .55rem; }
  .footer__signature span { width: 6px; height: 6px; border-radius: 50%; background: #22c55e; box-shadow: 0 0 12px rgba(34,197,94,.8); }

  .footer a:focus-visible,
  .footer button:focus-visible,
  .footer input:focus-visible {
    outline: 2px solid #4ade80;
    outline-offset: 3px;
  }

  @media (max-width: 820px) {
    .footer__newsletter { grid-template-columns: 1fr; gap: 1.65rem; }
    .footer__main { grid-template-columns: 1.4fr .8fr .8fr; gap: 2rem; }
  }

  @media (max-width: 620px) {
    .footer { padding-top: 3rem; }
    .footer__newsletter { margin-bottom: 3.25rem; padding: 1.35rem; border-radius: 19px; }
    .footer__form { flex-direction: column; }
    .footer__submit { width: 100%; }
    .footer__main { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
    .footer__desc { max-width: none; }
    .footer__bottom { align-items: flex-start; flex-direction: column; gap: .75rem; }
  }

  @media (max-width: 380px) {
    .footer__main { grid-template-columns: 1fr; }
    .footer__brand { grid-column: auto; }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer *, .footer *::before, .footer *::after { scroll-behavior: auto !important; transition-duration: .01ms !important; }
  }
</style>

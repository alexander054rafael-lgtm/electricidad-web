---
import Container from '../ui/Container.astro';
import Button from '../ui/Button.astro';
import { Download, BookOpen, CheckCircle } from '@lucide/astro';

const features = [
  'Fundamentos de electricidad industrial',
  'Diagramas unifilares y trifilares',
  'Protecciones y tableros eléctricos',
  'Introducción a PLC y automatización',
];
---

<section class="ebook" id="ebook">
  <Container>
    <div class="ebook__inner reveal">
      <div class="ebook__visual">
        <div class="ebook__glow" aria-hidden="true"></div>
        <div class="ebook__book">
          <div class="ebook__book-spine"></div>
          <div class="ebook__book-cover">
            <div class="ebook__book-badge">GRATIS</div>
            <BookOpen size={48} stroke-width={1.5} class="ebook__book-icon" />
            <h3 class="ebook__book-title">Guía Completa de Electricidad Industrial</h3>
            <p class="ebook__book-author">InduTech Academy</p>
            <div class="ebook__book-lines" aria-hidden="true">
              <span></span><span></span><span></span><span></span>
            </div>
          </div>
          <div class="ebook__book-pages"></div>
        </div>
      </div>

      <div class="ebook__content">
        <span class="ebook__eyebrow">Ebook gratuito</span>
        <h2 class="ebook__title">Descarga tu guía esencial de Electricidad Industrial</h2>
        <p class="ebook__desc">
          Más de 120 páginas con conceptos fundamentales, diagramas explicativos y ejercicios prácticos. El recurso perfecto para iniciar tu carrera en automatización industrial.
        </p>

        <ul class="ebook__features">
          {features.map((feature) => (
            <li class="ebook__feature">
              <CheckCircle size={18} stroke-width={2} />
              {feature}
            </li>
          ))}
        </ul>

        <Button href="#" variant="primary" size="lg" class="ebook__btn">
          <Download size={20} stroke-width={2.5} />
          Descargar Gratis
        </Button>
      </div>
    </div>
  </Container>
</section>

<style>
  .ebook {
    padding-block: clamp(5rem, 10vw, 8rem);
    background: var(--color-gray-50);
  }

  .ebook__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
    padding: clamp(2rem, 5vw, 4rem);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .ebook__inner {
      grid-template-columns: 1fr 1.2fr;
    }
  }

  .ebook__visual {
    position: relative;
    display: flex;
    justify-content: center;
    perspective: 1000px;
  }

  .ebook__glow {
    position: absolute;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, var(--color-hero-glow) 0%, transparent 70%);
    filter: blur(40px);
  }

  .ebook__book {
    position: relative;
    transform: rotateY(-12deg) rotateX(4deg);
    transform-style: preserve-3d;
    transition: transform var(--transition-slow);
    animation: book-float 6s ease-in-out infinite;
  }

  .ebook__inner:hover .ebook__book {
    transform: rotateY(-8deg) rotateX(2deg) translateY(-8px);
  }

  @keyframes book-float {
    0%, 100% { transform: rotateY(-12deg) rotateX(4deg) translateY(0); }
    50%      { transform: rotateY(-12deg) rotateX(4deg) translateY(-12px); }
  }

  .ebook__book-spine {
    position: absolute;
    left: -12px;
    top: 4px;
    width: 24px;
    height: calc(100% - 8px);
    background: linear-gradient(to right, #0f172a, #14532d);
    border-radius: 4px 0 0 4px;
    transform: rotateY(90deg) translateZ(-12px);
  }

  .ebook__book-cover {
    position: relative;
    width: 220px;
    height: 300px;
    padding: 2rem 1.5rem;
    background: linear-gradient(145deg, var(--color-primary-dark) 0%, var(--color-primary) 60%, var(--color-primary-light) 100%);
    border-radius: 4px 12px 12px 4px;
    box-shadow:
      8px 12px 32px rgba(15, 23, 42, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
    display: flex;
    flex-direction: column;
    color: white;
  }

  .ebook__book-pages {
    position: absolute;
    right: -6px;
    top: 6px;
    width: 8px;
    height: calc(100% - 12px);
    background: repeating-linear-gradient(
      to bottom,
      #f8fafc 0px,
      #f8fafc 2px,
      #e2e8f0 2px,
      #e2e8f0 4px
    );
    border-radius: 0 2px 2px 0;
  }

  .ebook__book-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    padding: 0.25rem 0.625rem;
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(4px);
    border-radius: var(--radius-full);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.06em;
  }

  .ebook__book-icon {
    margin-bottom: 1rem;
    opacity: 0.9;
  }

  .ebook__book-title {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 0.5rem;
    color: white;
  }

  .ebook__book-author {
    font-size: 0.75rem;
    opacity: 0.7;
    margin-bottom: auto;
  }

  .ebook__book-lines {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 1.5rem;
  }

  .ebook__book-lines span {
    height: 3px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 2px;
  }

  .ebook__book-lines span:nth-child(1) { width: 100%; }
  .ebook__book-lines span:nth-child(2) { width: 85%; }
  .ebook__book-lines span:nth-child(3) { width: 70%; }
  .ebook__book-lines span:nth-child(4) { width: 90%; }

  .ebook__eyebrow {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .ebook__title {
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .ebook__desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }

  .ebook__features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .ebook__feature {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text);
  }

  .ebook__feature :global(svg) {
    color: var(--color-primary);
    flex-shrink: 0;
  }
</style>

---
import { Archive, Ellipsis, Eye, FilePenLine, Send, Trash2 } from '@lucide/astro';
import type { CourseStatus } from '../../../types/course';

interface Props {
  course: { id: string; title: string; slug: string; status: CourseStatus };
  returnTo?: string;
}
const { course, returnTo = '/admin/cursos' } = Astro.props;
const endpoint = `/api/admin/courses/${course.id}`;
---
<details class="course-actions">
  <summary aria-label={`Abrir acciones de ${course.title}`}><Ellipsis size={18} aria-hidden="true" /></summary>
  <div class="action-menu">
    <a href={`/admin/cursos/${course.id}/editar`}><FilePenLine size={15} aria-hidden="true" /> Editar</a>
    {course.status === 'published' && <a href={`/cursos/${course.slug}`} target="_blank" rel="noopener noreferrer"><Eye size={15} aria-hidden="true" /> Ver vista pública</a>}
    {course.status === 'draft' && <form method="post" action={endpoint}><input type="hidden" name="intent" value="change-status" /><input type="hidden" name="status" value="published" /><input type="hidden" name="return_to" value={returnTo} /><button type="submit"><Send size={15} aria-hidden="true" /> Publicar</button></form>}
    {course.status === 'published' && <form method="post" action={endpoint}><input type="hidden" name="intent" value="change-status" /><input type="hidden" name="status" value="draft" /><input type="hidden" name="return_to" value={returnTo} /><button type="submit"><FilePenLine size={15} aria-hidden="true" /> Despublicar</button></form>}
    {course.status === 'archived' && <form method="post" action={endpoint}><input type="hidden" name="intent" value="change-status" /><input type="hidden" name="status" value="draft" /><input type="hidden" name="return_to" value={returnTo} /><button type="submit"><FilePenLine size={15} aria-hidden="true" /> Pasar a borrador</button></form>}
    {course.status !== 'archived' && <form method="post" action={endpoint} data-confirm-course-archive><input type="hidden" name="intent" value="change-status" /><input type="hidden" name="status" value="archived" /><input type="hidden" name="return_to" value={returnTo} /><button type="submit"><Archive size={15} aria-hidden="true" /> Archivar</button></form>}
    <button class="delete-action" type="button" data-delete-course data-course-id={course.id} data-course-name={course.title} data-return-to={returnTo}><Trash2 size={15} aria-hidden="true" /> Eliminar</button>
  </div>
</details>
<script>
  document.querySelectorAll<HTMLFormElement>('[data-confirm-course-archive]').forEach((form) => {
    if (form.dataset.confirmReady === 'true') return;
    form.dataset.confirmReady = 'true';
    form.addEventListener('submit', (event) => {
      if (!window.confirm('¿Quieres archivar este curso? Dejará de estar disponible públicamente.')) event.preventDefault();
    });
  });
</script>
<style>
  .course-actions { position:relative; display:inline-block; }
  summary { display:grid; width:36px; height:36px; place-items:center; border:1px solid var(--admin-border-strong); border-radius:9px; color:var(--admin-text-muted); cursor:pointer; list-style:none; }
  summary::-webkit-details-marker { display:none; }
  summary:hover { border-color:var(--admin-green); color:var(--admin-text); }
  summary:focus-visible { outline:2px solid var(--admin-green); outline-offset:2px; }
  .action-menu { position:absolute; z-index:20; top:calc(100% + .4rem); right:0; display:grid; width:205px; overflow:hidden; padding:.35rem; border:1px solid var(--admin-border-strong); border-radius:11px; background:var(--admin-surface-raised); box-shadow:0 18px 45px rgba(0,0,0,.38); }
  form { margin:0; }
  a,button { display:flex; width:100%; min-height:36px; align-items:center; gap:.5rem; padding:.48rem .58rem; border:0; border-radius:7px; background:transparent; color:var(--admin-text-muted); font:inherit; font-size:.67rem; font-weight:700; text-align:left; cursor:pointer; }
  a:hover,button:hover { background:var(--admin-surface-soft); color:var(--admin-text); }
  a:focus-visible,button:focus-visible { outline:2px solid var(--admin-green); outline-offset:-2px; }
  .delete-action { margin-top:.2rem; border-top:1px solid var(--admin-border); border-radius:0 0 7px 7px; color:#ff9c9c; }
  @media(max-width:720px){.action-menu{position:static;width:100%;margin-top:.45rem}.course-actions{display:block;width:100%}summary{width:100%}}
</style>

---
import type { CourseStatus } from '../../../types/course';
import { translateCourseStatus } from '../../../lib/admin/course-utils';

interface Props { status: CourseStatus }
const { status } = Astro.props;
---
<span class:list={['course-badge', status]}><span aria-hidden="true"></span>{translateCourseStatus(status)}</span>
<style>
  .course-badge { display:inline-flex; min-height:25px; align-items:center; gap:.4rem; padding:.25rem .52rem; border:1px solid var(--admin-border-strong); border-radius:999px; background:var(--admin-surface-soft); color:var(--admin-text-muted); font-size:.63rem; font-weight:800; line-height:1; white-space:nowrap; }
  .course-badge > span { width:6px; height:6px; flex:none; border-radius:50%; background:currentColor; box-shadow:0 0 0 3px color-mix(in srgb,currentColor 13%,transparent); }
  .published { border-color:color-mix(in srgb,var(--admin-green) 28%,var(--admin-border)); background:var(--admin-green-soft); color:var(--admin-green); }
  .archived { border-color:color-mix(in srgb,var(--admin-warning) 28%,var(--admin-border)); background:var(--admin-warning-soft); color:var(--admin-warning); }
</style>

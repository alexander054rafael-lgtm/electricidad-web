---
import type { CourseLevel } from '../../../types/course';
import { translateCourseLevel } from '../../../lib/admin/course-utils';

interface Props { level: CourseLevel }
const { level } = Astro.props;
---
<span class:list={['course-badge', level]}><span aria-hidden="true"></span>{translateCourseLevel(level)}</span>
<style>
  .course-badge { display:inline-flex; min-height:25px; align-items:center; gap:.4rem; padding:.25rem .52rem; border:1px solid var(--admin-border-strong); border-radius:999px; background:var(--admin-surface-soft); color:var(--admin-text-muted); font-size:.63rem; font-weight:800; line-height:1; white-space:nowrap; }
  .course-badge > span { width:6px; height:6px; flex:none; border-radius:50%; background:currentColor; box-shadow:0 0 0 3px color-mix(in srgb,currentColor 13%,transparent); }
  .beginner { border-color:color-mix(in srgb,var(--admin-blue) 24%,var(--admin-border)); background:var(--admin-blue-soft); color:#86c4ff; }
  .intermediate { color:#d1d8d4; }
  .advanced { border-color:color-mix(in srgb,var(--admin-danger) 25%,var(--admin-border)); background:color-mix(in srgb,var(--admin-danger) 11%,transparent); color:#ff9c9c; }
</style>

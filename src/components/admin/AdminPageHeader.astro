---
interface Props {
  title: string;
  description: string;
  eyebrow?: string;
  actionHref?: string;
  actionLabel?: string;
}

const { title, description, eyebrow = 'Administración', actionHref, actionLabel } = Astro.props;
---

<header class="page-header">
  <div>
    <span>{eyebrow}</span>
    <h1>{title}</h1>
    <p>{description}</p>
  </div>
  {actionHref && actionLabel && (
    <a href={actionHref}><slot name="action-icon" /><span>{actionLabel}</span></a>
  )}
</header>

<style>
  .page-header { display: flex; align-items: end; justify-content: space-between; gap: 1.5rem; margin-bottom: 1.5rem; }
  .page-header > div { min-width: 0; }
  .page-header > div > span { color: var(--admin-green); font-size: 0.68rem; font-weight: 850; letter-spacing: 0.09em; text-transform: uppercase; }
  h1 { margin: 0.28rem 0 0.38rem; color:var(--admin-text); font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.04em; line-height: 1.05; }
  p { max-width: 760px; margin: 0; color: var(--admin-text-muted); line-height:1.6; }
  a { display: inline-flex; min-height:44px; flex:none; align-items:center; justify-content:center; gap:.45rem; padding:.75rem 1rem; border:1px solid rgba(66,201,119,.28); border-radius:10px; background:var(--admin-green-strong); color:#fff; font-size:.76rem; font-weight:800; box-shadow:0 10px 24px rgba(0,0,0,.18); }
  a:hover { background:#2db766; }
  a:focus-visible { outline: 2px solid var(--admin-green); outline-offset: 3px; }
  @media (max-width: 640px) { .page-header { align-items: stretch; flex-direction: column; } a { justify-content: center; } }
</style>

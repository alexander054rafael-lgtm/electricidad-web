---
import { AlertCircle, Upload } from '@lucide/astro';
---
<form class="upload-form" data-upload-form novalidate>
  <div class="upload-form__notice"><AlertCircle size={18}/><p><strong>Modo demostración.</strong> La publicación requiere conectar Supabase Authentication y Storage. No se envían archivos desde esta página.</p></div>
  <div class="upload-form__grid"><label>Título*<input name="title" required /></label><label>Autor*<input name="author" required /></label><label>Categoría*<select required><option value="">Selecciona</option><option>Electricidad Industrial</option><option>Automatización</option><option>PLC</option><option>Variadores de Frecuencia</option><option>Motores Eléctricos</option><option>Instrumentación</option><option>Electrónica</option><option>Seguridad Eléctrica</option></select></label><label>Nivel*<select required><option value="">Selecciona</option><option>Básico</option><option>Intermedio</option><option>Avanzado</option></select></label><label>Idioma*<input value="Español" required /></label><label>Páginas*<input type="number" min="1" required /></label><label>Año de publicación*<input type="number" min="1900" max="2100" required /></label><label>Estado*<select required><option>Borrador</option><option>Publicado</option></select></label></div><label>Descripción*<textarea rows="5" required></textarea></label><label>Etiquetas <input placeholder="PLC, Siemens, automatización" /></label><div class="upload-form__grid"><label>Portada*<input type="file" accept="image/png,image/jpeg,image/webp" required data-cover /></label><label>Archivo PDF*<input type="file" accept="application/pdf" required data-pdf /></label></div><div class="upload-form__preview" data-preview hidden><img alt="Vista previa de portada" /></div><p class="upload-form__error" aria-live="polite" data-form-error></p><button type="submit"><Upload size={18}/> Validar publicación</button></form>
<script>
  const form = document.querySelector<HTMLFormElement>('[data-upload-form]'); const error = document.querySelector<HTMLElement>('[data-form-error]'); const preview = document.querySelector<HTMLElement>('[data-preview]'); const cover = document.querySelector<HTMLInputElement>('[data-cover]');
  cover?.addEventListener('change', () => { const file = cover.files?.[0]; const image = preview?.querySelector('img'); if (file && image && preview) { image.src = URL.createObjectURL(file); preview.hidden = false; } });
  form?.addEventListener('submit', (event) => { event.preventDefault(); const pdf = document.querySelector<HTMLInputElement>('[data-pdf]')?.files?.[0]; const image = cover?.files?.[0]; const valid = form.checkValidity() && pdf?.type === 'application/pdf' && (!pdf || pdf.size <= 25 * 1024 * 1024) && image?.type.startsWith('image/'); if (error) error.textContent = valid ? 'Los campos son válidos. Conecta Supabase para guardar y publicar este libro.' : 'Revisa los campos obligatorios. El PDF debe pesar como máximo 25 MB y la portada debe ser una imagen válida.'; form.classList.toggle('is-valid', Boolean(valid)); });
</script>
<style>.upload-form{display:grid;gap:1.2rem;padding:clamp(1.25rem,4vw,2rem);border:1px solid var(--color-border);border-radius:var(--radius-xl);background:var(--color-surface);box-shadow:var(--shadow-md)}.upload-form label{display:grid;gap:.4rem;font-size:.84rem;font-weight:700}.upload-form input,.upload-form select,.upload-form textarea{width:100%;padding:.7rem .8rem;border:1px solid var(--color-border);border-radius:9px;background:var(--color-white);font:inherit}.upload-form__grid{display:grid;grid-template-columns:1fr;gap:1rem}@media(min-width:700px){.upload-form__grid{grid-template-columns:repeat(2,1fr)}}.upload-form__notice{display:flex;gap:.65rem;padding:.9rem;border-radius:10px;background:#fffbeb;color:#854d0e;font-size:.85rem}.upload-form__preview img{max-height:180px;border-radius:10px}.upload-form__error{min-height:1.4em;color:#b91c1c;font-size:.85rem}.upload-form.is-valid .upload-form__error{color:var(--color-primary-dark)}.upload-form button{display:inline-flex;justify-content:center;align-items:center;gap:.5rem;padding:.8rem 1rem;border-radius:10px;background:var(--color-primary);color:white;font:inherit;font-weight:800}</style>

---
import { Upload } from '@lucide/astro';
---
<form class="upload-form" data-book-form enctype="multipart/form-data" novalidate>
  <div class="grid"><label>Título*<input name="title" required minlength="3" /></label><label>Autor*<input name="author" required minlength="2" /></label><label>Categoría*<select name="category" required><option value="">Selecciona</option><option>Electricidad Industrial</option><option>Automatización</option><option>PLC</option><option>Variadores de Frecuencia</option><option>Motores Eléctricos</option><option>Instrumentación</option><option>Electrónica Industrial</option><option>Seguridad Eléctrica</option></select></label><label>Nivel*<select name="level"><option>Básico</option><option>Intermedio</option><option>Avanzado</option></select></label><label>Idioma*<input name="language" value="Español" required /></label><label>Páginas*<input name="pages" type="number" min="1" required /></label><label>Año*<input name="publicationYear" type="number" min="1800" max="2200" required /></label><label>Estado<select name="status"><option value="draft">Borrador</option><option value="published">Publicado</option></select></label></div>
  <label>Descripción*<textarea name="description" rows="5" required></textarea></label><label>Etiquetas<input name="tags" placeholder="PLC, Siemens, automatización" /></label><label class="check"><input name="allowDownload" type="checkbox" /> Permitir descarga a usuarios autorizados</label>
  <div class="grid"><label>Portada* (JPG, PNG o WebP; 5 MB)<input name="cover" type="file" accept="image/jpeg,image/png,image/webp" required data-cover /></label><label>PDF* (50 MB máximo)<input name="pdf" type="file" accept="application/pdf" required /></label></div><div data-preview hidden><img alt="Vista previa de portada" /></div><p class="message" aria-live="polite" data-message></p><button type="submit"><Upload size={18}/> Guardar libro</button>
</form>
<script>
 const form=document.querySelector<HTMLFormElement>('[data-book-form]');const message=form?.querySelector<HTMLElement>('[data-message]');const cover=form?.querySelector<HTMLInputElement>('[data-cover]');const preview=form?.querySelector<HTMLElement>('[data-preview]');let previewUrl='';
 cover?.addEventListener('change',()=>{if(previewUrl)URL.revokeObjectURL(previewUrl);const file=cover.files?.[0];const img=preview?.querySelector('img');if(file&&img&&preview){previewUrl=URL.createObjectURL(file);img.src=previewUrl;preview.hidden=false}});
 form?.addEventListener('submit',async(event)=>{event.preventDefault();if(!form.checkValidity()){form.reportValidity();return}if(message)message.textContent='Validando y cargando…';const response=await fetch('/api/admin/books/save',{method:'POST',body:new FormData(form)});const result=await response.json();if(message){message.textContent=response.ok?'Libro guardado correctamente.':result.error??'No se pudo guardar.';message.dataset.state=response.ok?'ok':'error'}if(response.ok)setTimeout(()=>location.reload(),600)});
</script>
<style>.upload-form{display:grid;gap:1rem;padding:1.3rem;border:1px solid #dce5df;border-radius:16px;background:#fff}.grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}label{display:grid;gap:.4rem;font-size:.84rem;font-weight:750}.check{display:flex;align-items:center}input,select,textarea{width:100%;padding:.72rem;border:1px solid #cad7ce;border-radius:9px;font:inherit}.check input{width:auto}button{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;padding:.8rem;border-radius:9px;background:#16833e;color:#fff;font:inherit;font-weight:800}.message[data-state="error"]{color:#b42318}.message[data-state="ok"]{color:#166534}[data-preview] img{max-width:180px;max-height:140px;border-radius:10px}@media(max-width:650px){.grid{grid-template-columns:1fr}}</style>

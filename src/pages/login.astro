    <button type="submit">Ingresar</button>
  </form>
  <div class="auth-form__links"><a href="/recuperar-contrasena">OlvidÃ© mi contraseÃ±a</a><span>Â¿AÃºn no tienes cuenta? <a href="/registro">RegÃ­strate</a></span></div>
</AuthShell>

<script>
  const initializePasswordToggle = () => {
    const input = document.querySelector<HTMLInputElement>('#login-password');
    const button = document.querySelector<HTMLButtonElement>('[data-password-toggle]');

    if (!input || !button || button.dataset.passwordToggleInitialized === 'true') return;

    button.dataset.passwordToggleInitialized = 'true';
    button.addEventListener('click', () => {
      const willShowPassword = input.type === 'password';
      const label = willShowPassword ? 'Ocultar contraseÃ±a' : 'Mostrar contraseÃ±a';

      input.type = willShowPassword ? 'text' : 'password';
      button.setAttribute('aria-label', label);
      button.setAttribute('title', label);
      button.setAttribute('aria-pressed', String(willShowPassword));
    });
  };

  initializePasswordToggle();
  document.addEventListener('astro:page-load', initializePasswordToggle);
</script>

---
export const prerender = false;
import AuthShell from '../components/auth/AuthShell.astro';
import { getSupabaseConfig } from '../lib/supabase/config';
import { safeRedirectPath } from '../lib/supabase/server';

const { isSupabaseConfigured } = getSupabaseConfig();
let error = Astro.url.searchParams.get('error') === 'confirmation' ? 'No se pudo confirmar la sesiÃ³n. Solicita un nuevo enlace.' : '';
const redirectTo = safeRedirectPath(Astro.url.searchParams.get('redirect'));
if (Astro.locals.user && Astro.request.method === 'GET') return Astro.redirect(redirectTo, 303);

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = String(form.get('email') ?? '').trim().toLowerCase();
  const password = String(form.get('password') ?? '');
  if (!Astro.locals.supabase) error = 'Supabase todavÃ­a no estÃ¡ configurado. Revisa las variables del servidor.';
  else if (!/^\S+@\S+\.\S+$/.test(email) || password.length < 8) error = 'Ingresa un correo vÃ¡lido y una contraseÃ±a de al menos 8 caracteres.';
  else {
    const { error: signInError } = await Astro.locals.supabase.auth.signInWithPassword({ email, password });
    if (signInError) error = 'No fue posible iniciar sesiÃ³n. Revisa tus credenciales o confirma tu correo.';
    else return Astro.redirect(safeRedirectPath(String(form.get('redirect') ?? '')), 303);
  }
}
---
<AuthShell title="Iniciar sesiÃ³n" eyebrow="Acceso de estudiantes" description="ContinÃºa tus cursos, evaluaciones y actividades desde cualquier dispositivo.">
  {!isSupabaseConfigured && <p class="auth-message auth-message--error">ConfiguraciÃ³n pendiente: copia <code>.env.example</code> a <code>.env</code> y aÃ±ade las credenciales pÃºblicas de Supabase.</p>}
  {error && <p class="auth-message auth-message--error" role="alert">{error}</p>}
  <form class="auth-form" method="post">
    <input type="hidden" name="redirect" value={redirectTo} />
    <label>Correo electrÃ³nico<input type="email" name="email" autocomplete="email" required /></label>
    <div class="auth-form__field">
      <label for="login-password">ContraseÃ±a</label>
      <div class="password-field">
        <input id="login-password" type="password" name="password" autocomplete="current-password" minlength="8" required />
        <button class="password-toggle" type="button" aria-label="Mostrar contraseÃ±a" title="Mostrar contraseÃ±a" aria-pressed="false" data-password-toggle>
          <svg class="password-toggle__icon password-toggle__icon--show" aria-hidden="true" viewBox="0 0 24 24" width="19" height="19" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">

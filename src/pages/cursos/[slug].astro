---
export const prerender = false;

import { ArrowLeft, BookOpen, Clock3, Gauge, ImageOff, Layers, UserRound, Zap } from '@lucide/astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/landing/Header.astro';
import Footer from '../../components/landing/Footer.astro';
import { formatCourseDuration, translateCourseLevel } from '../../lib/admin/course-utils';
import type { Course } from '../../types/course';

const slug = (Astro.params.slug ?? '').trim();
const supabase = Astro.locals.supabase;
const result = supabase && slug
  ? await supabase
      .from('courses')
      .select('id,title,slug,short_description,description,cover_url,category,level,status,duration_minutes,position,is_featured,instructor_id,created_by,created_at,updated_at,published_at,instructor:profiles!courses_instructor_id_fkey(id,full_name,avatar_url)')
      .eq('slug', slug)
      .eq('status', 'published')
      .maybeSingle()
  : { data: null, error: null };

if (result.error && import.meta.env.DEV) {
  console.error('[public-course-detail] No se pudo cargar el curso publicado:', result.error);
}

const course = result.data as Course | null;
const notFound = !course || course.status !== 'published';
if (notFound) Astro.response.status = 404;
const validCover = Boolean(course?.cover_url && /^https:\/\//i.test(course.cover_url));
---

<Layout
  title={course ? `${course.title} | InduTech Academy` : 'Curso no encontrado | InduTech Academy'}
  description={course?.short_description || 'Curso técnico de InduTech Academy.'}
>
  <Header />
  <main class="public-course-main">
    {notFound ? (
      <section class="not-found container" aria-labelledby="not-found-title">
        <span><BookOpen size={30} aria-hidden="true" /></span>
        <p>Catálogo de cursos</p>
        <h1 id="not-found-title">Curso no encontrado</h1>
        <div>El curso solicitado no existe o todavía no está disponible públicamente.</div>
        <a href="/cursos"><ArrowLeft size={17} aria-hidden="true" /> Volver a cursos</a>
      </section>
    ) : course && (
      <>
        <section class="course-hero">
          <div class="container hero-grid">
            <div class="hero-copy">
              <a class="back-link" href="/cursos"><ArrowLeft size={16} aria-hidden="true" /> Todos los cursos</a>
              <span class="eyebrow"><Zap size={14} aria-hidden="true" /> Formación técnica</span>
              <h1>{course.title}</h1>
              {course.short_description && <p>{course.short_description}</p>}
              <div class="course-meta" aria-label="Información del curso">
                <span><Layers size={17} aria-hidden="true" /><small>Categoría</small><strong>{course.category || 'General'}</strong></span>
                <span><Gauge size={17} aria-hidden="true" /><small>Nivel</small><strong>{translateCourseLevel(course.level)}</strong></span>
                <span><Clock3 size={17} aria-hidden="true" /><small>Duración</small><strong>{formatCourseDuration(course.duration_minutes)}</strong></span>
                {course.instructor && <span><UserRound size={17} aria-hidden="true" /><small>Instructor</small><strong>{course.instructor.full_name || 'Perfil profesional'}</strong></span>}
              </div>
            </div>

            <div class="hero-cover">
              <div class="cover-fallback"><ImageOff size={30} aria-hidden="true" /><span>Portada del curso</span></div>
              {validCover && <img src={course.cover_url!} alt={`Portada de ${course.title}`} width="1280" height="720" loading="eager" data-public-cover />}
            </div>
          </div>
        </section>

        <div class="course-content container">
          <article class="description-card">
            <span>Acerca del curso</span>
            <h2>Descripción</h2>
            <div class="description-text">{course.description || course.short_description || 'La descripción completa estará disponible próximamente.'}</div>
          </article>

          <section class="coming-soon" aria-labelledby="coming-soon-title">
            <span><BookOpen size={26} aria-hidden="true" /></span>
            <div>
              <small>Programa formativo</small>
              <h2 id="coming-soon-title">Contenido próximamente</h2>
              <p>Los módulos y lecciones de este curso se publicarán en una siguiente etapa.</p>
            </div>
          </section>
        </div>
      </>
    )}
  </main>
  <Footer />
</Layout>

<script>
  const publicCover = document.querySelector<HTMLImageElement>('[data-public-cover]');
  const hideBrokenCover = () => { if (publicCover) publicCover.hidden = true; };
  publicCover?.addEventListener('error', hideBrokenCover);
  if (publicCover?.complete && publicCover.naturalWidth === 0) hideBrokenCover();
</script>

<style>
  .public-course-main { min-height: 72vh; background: var(--color-gray-50); }
  .course-hero { padding: calc(var(--header-height) + clamp(3rem, 7vw, 6rem)) 0 clamp(3rem, 7vw, 5rem); background: linear-gradient(145deg, #f4fbf6, #f8fafc 62%, #eef7ff); border-bottom: 1px solid var(--color-border); }
  .hero-grid { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(360px, .85fr); align-items: center; gap: clamp(2rem, 6vw, 5rem); }
  .hero-copy { min-width: 0; }
  .back-link { display: inline-flex; align-items: center; gap: .4rem; margin-bottom: 2rem; color: var(--color-text-secondary); font-size: .78rem; font-weight: 700; }
  .back-link:hover { color: var(--color-primary); }
  .back-link:focus-visible, .not-found a:focus-visible { outline: 3px solid rgba(22, 163, 74, .28); outline-offset: 4px; border-radius: 5px; }
  .eyebrow { display: inline-flex; align-items: center; gap: .4rem; color: var(--color-primary); font-size: .72rem; font-weight: 850; letter-spacing: .08em; text-transform: uppercase; }
  h1 { max-width: 850px; margin: .7rem 0 1rem; color: var(--color-text); font-size: clamp(2.35rem, 6vw, 4.6rem); letter-spacing: -.055em; line-height: 1.02; }
  .hero-copy > p { max-width: 760px; margin: 0; color: var(--color-text-secondary); font-size: clamp(1rem, 2vw, 1.18rem); line-height: 1.75; }
  .course-meta { display: flex; flex-wrap: wrap; gap: .75rem; margin-top: 2rem; }
  .course-meta > span { display: grid; grid-template-columns: auto 1fr; align-items: center; column-gap: .5rem; min-width: 145px; padding: .75rem .9rem; border: 1px solid var(--color-border); border-radius: 13px; background: rgba(255,255,255,.72); box-shadow: var(--shadow-sm); }
  .course-meta :global(svg) { grid-row: 1 / 3; color: var(--color-primary); }
  .course-meta small { color: var(--color-text-muted); font-size: .63rem; }
  .course-meta strong { color: var(--color-text); font-size: .78rem; }
  .hero-cover { position: relative; display: grid; aspect-ratio: 16 / 9; overflow: hidden; place-items: center; border: 1px solid rgba(22,163,74,.16); border-radius: clamp(18px, 3vw, 28px); background: linear-gradient(145deg, #10271a, #153824); box-shadow: 0 28px 70px rgba(15, 70, 35, .2); }
  .cover-fallback { display: grid; place-items: center; gap: .65rem; color: #72db98; font-weight: 750; }
  .hero-cover img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .hero-cover img[hidden] { display: none; }
  .course-content { display: grid; grid-template-columns: minmax(0, 1fr) minmax(300px, 410px); align-items: start; gap: clamp(1rem, 3vw, 2rem); padding-block: clamp(3rem, 7vw, 6rem); }
  .description-card, .coming-soon { border: 1px solid var(--color-border); border-radius: var(--radius-xl); background: var(--color-surface); box-shadow: var(--shadow-sm); }
  .description-card { padding: clamp(1.3rem, 4vw, 2.2rem); }
  .description-card > span, .coming-soon small { color: var(--color-primary); font-size: .67rem; font-weight: 850; letter-spacing: .08em; text-transform: uppercase; }
  .description-card h2, .coming-soon h2 { margin: .3rem 0 .8rem; color: var(--color-text); font-size: clamp(1.4rem, 3vw, 2rem); }
  .description-text { color: var(--color-text-secondary); line-height: 1.85; white-space: pre-line; }
  .coming-soon { display: flex; align-items: flex-start; gap: .85rem; padding: 1.3rem; }
  .coming-soon > span { display: grid; width: 48px; height: 48px; flex: none; place-items: center; border-radius: 14px; background: rgba(22, 163, 74, .09); color: var(--color-primary); }
  .coming-soon h2 { margin-bottom: .4rem; font-size: 1.15rem; }
  .coming-soon p { margin: 0; color: var(--color-text-secondary); font-size: .82rem; line-height: 1.6; }
  .not-found { display: grid; min-height: 72vh; padding-top: calc(var(--header-height) + 3rem); place-items: center; align-content: center; text-align: center; }
  .not-found > span { display: grid; width: 66px; height: 66px; place-items: center; border-radius: 18px; background: rgba(22,163,74,.1); color: var(--color-primary); }
  .not-found > p { margin: 1.1rem 0 0; color: var(--color-primary); font-size: .7rem; font-weight: 850; text-transform: uppercase; }
  .not-found h1 { margin: .35rem 0 .7rem; font-size: clamp(2rem, 7vw, 3.5rem); }
  .not-found > div { max-width: 520px; color: var(--color-text-secondary); line-height: 1.65; }
  .not-found a { display: inline-flex; min-height: 44px; align-items: center; gap: .45rem; margin-top: 1.4rem; padding: .7rem 1rem; border-radius: 999px; background: var(--color-primary); color: #fff; font-weight: 800; }
  @media (max-width: 900px) { .hero-grid, .course-content { grid-template-columns: 1fr; } .hero-cover { width: min(100%, 720px); } }
  @media (max-width: 600px) { .course-hero { padding-inline: 1rem; } .course-content { padding-inline: 1rem; } .course-meta { display: grid; grid-template-columns: 1fr; } .course-meta > span { min-width: 0; } }
  @media (prefers-reduced-motion: reduce) { * { scroll-behavior: auto; } }
</style>

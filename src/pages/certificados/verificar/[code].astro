---
export const prerender = false;
import { BadgeCheck, BadgeX } from '@lucide/astro';
import Layout from '../../../layouts/Layout.astro'; import Header from '../../../components/landing/Header.astro'; import Footer from '../../../components/landing/Footer.astro';
const code = String(Astro.params.code ?? '').toLowerCase();
interface CertificateRecord { verification_code:string; student_name:string|null; course_title:string; final_grade:number; issued_at:string; status:string }
let certificate: CertificateRecord | null = null;
let unavailable = false;
if (!/^[a-f0-9]{24}$/.test(code)) certificate = null;
else if (!Astro.locals.supabase) unavailable = true;
else { const { data } = await Astro.locals.supabase.rpc('verify_certificate', { p_code: code }); certificate = (data?.[0] as CertificateRecord | undefined) ?? null; }
---
<Layout title="Verificar certificado | InduTech Academy" description="Verificación pública de certificados técnicos."><Header /><main class="verify"><section class:list={['verify-card',{invalid:!certificate}]}>{certificate ? <><BadgeCheck size={54} /><span>Certificado válido</span><h1>{certificate.course_title}</h1><dl><div><dt>Estudiante</dt><dd>{certificate.student_name || 'Nombre no disponible'}</dd></div><div><dt>Nota final</dt><dd>{certificate.final_grade}%</dd></div><div><dt>Fecha de emisión</dt><dd>{new Intl.DateTimeFormat('es-PE',{dateStyle:'long'}).format(new Date(certificate.issued_at))}</dd></div><div><dt>Código</dt><dd><code>{certificate.verification_code}</code></dd></div></dl></> : <><BadgeX size={54} /><span>{unavailable?'Servicio no configurado':'Certificado no encontrado'}</span><h1>{unavailable?'Configura Supabase para verificar':'El código no es válido'}</h1><p>{unavailable?'La página está preparada, pero necesita las variables públicas del proyecto.':'Comprueba que el código esté completo y que el certificado no haya sido revocado.'}</p></>}</section></main><Footer /></Layout>
<style>.verify{display:grid;min-height:75vh;place-items:center;padding:calc(var(--header-height) + 3rem) 1rem 5rem;background:var(--color-gray-50)}.verify-card{width:100%;max-width:650px;padding:clamp(1.5rem,5vw,3rem);border:1px solid rgba(22,163,74,.25);border-radius:var(--radius-2xl);background:var(--color-surface);box-shadow:var(--shadow-xl);text-align:center}.verify-card>svg{margin:0 auto 1rem;color:var(--color-primary)}.verify-card>span{color:var(--color-primary);font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.09em}.verify-card h1{margin:.5rem 0 1.5rem;font-size:clamp(1.8rem,5vw,3rem)}dl{display:grid;grid-template-columns:1fr 1fr;text-align:left;border:1px solid var(--color-border);border-radius:16px}dl>div{padding:1rem}dl>div:nth-child(even){border-left:1px solid var(--color-border)}dl>div:nth-child(n+3){border-top:1px solid var(--color-border)}dt{color:var(--color-text-secondary);font-size:.65rem;text-transform:uppercase}dd{margin-top:.2rem;font-size:.82rem;font-weight:750}.invalid{border-color:var(--color-border)}.invalid>svg,.invalid>span{color:var(--color-text-secondary)}.invalid>p{color:var(--color-text-secondary)}@media(max-width:520px){dl{grid-template-columns:1fr}dl>div:nth-child(even){border-left:0}dl>div+div{border-top:1px solid var(--color-border)}}</style>

---
export const prerender = false;
import { BookOpen, CalendarClock, CircleCheckBig as CheckCircle2, CirclePlay, ClipboardCheck, Gamepad2, GraduationCap, History, UserRound } from '@lucide/astro';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/landing/Header.astro';
import Footer from '../../components/landing/Footer.astro';
import { courses as localCourses, getCourseLessons } from '../../data/courses';
import { assessments } from '../../data/assessments';
import { books } from '../../data/books';

const supabase = Astro.locals.supabase!; const user = Astro.locals.user!;
const [{ data: enrollmentData }, { data: progressData }, { data: assessmentData }, { data: gameData }, { data: lessonActivity }, { data: certificateData }] = await Promise.all([
  supabase.from('course_enrollments').select('id,status,enrolled_at,completed_at,course:courses(id,slug,title,description,total_lessons)').eq('user_id', user.id).order('enrolled_at', { ascending: false }),
  supabase.from('course_progress').select('*').eq('user_id', user.id),
  supabase.from('assessment_attempts').select('course_id,assessment_slug,percentage,passed,created_at').eq('user_id', user.id).order('created_at', { ascending: false }),
  supabase.from('game_attempts').select('game_slug,score,completed,created_at').eq('user_id', user.id).order('created_at', { ascending: false }).limit(20),
  supabase.from('lesson_progress').select('course_id,lesson_slug,status,updated_at').eq('user_id', user.id).order('updated_at', { ascending: false }).limit(20),
  supabase.from('certificates').select('verification_code,final_grade,issued_at,course:courses(title)').eq('user_id', user.id),
]);
type EnrollmentRow = { id:string; status:string; enrolled_at:string; course:{id:string;slug:string;title:string;description:string;total_lessons:number} | Array<{id:string;slug:string;title:string;description:string;total_lessons:number}> };
const enrollments = (enrollmentData ?? []) as EnrollmentRow[];
const progressRows = (progressData ?? []) as Array<{course_id:string;completed_lessons:number;total_lessons:number;progress_percent:number;last_lesson_slug:string|null;status:string;updated_at:string}>;
const progressByCourse = new Map(progressRows.map((row) => [row.course_id, row]));
const courseFor = (row: EnrollmentRow) => Array.isArray(row.course) ? row.course[0] : row.course;
const courseCards = enrollments.map((enrollment) => {
  const course = courseFor(enrollment); const progress = progressByCourse.get(course.id); const local = localCourses.find((item) => item.slug === course.slug); const lessons = local ? getCourseLessons(local) : [];
  const lastIndex = progress?.last_lesson_slug ? lessons.findIndex((lesson) => lesson.slug === progress.last_lesson_slug) : -1; const nextLesson = lessons[Math.min(lastIndex + 1, Math.max(lessons.length - 1, 0))];
  return { enrollment, course, local, progress, nextLesson, percent: Math.round(Number(progress?.progress_percent ?? 0)) };
});
const inProgress = courseCards.filter((item) => item.percent < 100); const finished = courseCards.filter((item) => item.percent >= 100);
const passedAssessments = new Set(((assessmentData ?? []) as Array<{assessment_slug:string;passed:boolean}>).filter((item) => item.passed).map((item) => item.assessment_slug));
const enrolledSlugs = new Set(courseCards.map((item) => item.course.slug));
const pendingAssessments = assessments.filter((item) => enrolledSlugs.has(item.courseSlug) && !passedAssessments.has(item.slug));
const completedGames = ((gameData ?? []) as Array<{completed:boolean}>).filter((item) => item.completed).length;
const recommendedBookIds = new Set(courseCards.flatMap((item) => item.local?.courseBookIds ?? [])); const recommendedBooks = books.filter((book) => recommendedBookIds.has(book.slug)).slice(0,4);
const recentActivity = [
  ...((lessonActivity ?? []) as Array<{lesson_slug:string;updated_at:string}>).map((item) => ({ title: `Lección: ${item.lesson_slug.replaceAll('-', ' ')}`, date: item.updated_at, type: 'Lección' })),
  ...((assessmentData ?? []) as Array<{assessment_slug:string;percentage:number;created_at:string}>).map((item) => ({ title: `Evaluación: ${item.assessment_slug.replaceAll('-', ' ')} · ${Math.round(Number(item.percentage))}%`, date: item.created_at, type: 'Evaluación' })),
  ...((gameData ?? []) as Array<{game_slug:string;score:number;created_at:string}>).map((item) => ({ title: `Juego: ${item.game_slug.replaceAll('-', ' ')} · ${item.score} puntos`, date: item.created_at, type: 'Juego' })),
].sort((a,b) => Date.parse(b.date)-Date.parse(a.date)).slice(0,6);
const displayName = Astro.locals.profile?.full_name?.split(' ')[0] || 'estudiante';
const permissionDenied = Astro.url.searchParams.get('error') === 'forbidden';
---
<Layout title="Mi aprendizaje | InduTech Academy" description="Panel personal de cursos, progreso y actividades."><Header /><main class="dashboard"><div class="container">{permissionDenied && <div class="permission-alert" role="alert">No tienes permiso para realizar esta acción.</div>}<header class="dashboard__header"><div><span>Panel del estudiante</span><h1>Hola, {displayName}</h1><p>Continúa desde donde lo dejaste y revisa tus próximos objetivos.</p></div><a href="/perfil"><UserRound size={18} /> Mi perfil</a></header><section class="summary"><article><GraduationCap /><strong>{inProgress.length}</strong><span>Cursos en progreso</span></article><article><CheckCircle2 /><strong>{finished.length}</strong><span>Cursos terminados</span></article><article><ClipboardCheck /><strong>{pendingAssessments.length}</strong><span>Evaluaciones pendientes</span></article><article><Gamepad2 /><strong>{completedGames}</strong><span>Juegos completados</span></article></section>
  <div class="dashboard-grid"><section class="panel panel--wide"><div class="panel__heading"><CirclePlay /><div><span>Continuar estudiando</span><h2>Cursos en progreso</h2></div></div>{inProgress.length ? <div class="course-list">{inProgress.map((item) => <article class="course-progress"><div><span>{item.course.title}</span><strong>{item.percent}%</strong></div><progress value={item.percent} max="100">{item.percent}%</progress><p>{item.progress?.completed_lessons ?? 0} de {item.course.total_lessons} lecciones completadas</p><a href={item.nextLesson?.href ?? `/cursos/${item.course.slug}`}>{item.nextLesson ? `Próxima: ${item.nextLesson.title}` : 'Abrir curso'}</a></article>)}</div> : <div class="empty"><p>Aún no tienes cursos en progreso.</p><a href="/cursos">Explorar cursos</a></div>}</section>
  <section class="panel"><div class="panel__heading"><ClipboardCheck /><div><span>Por completar</span><h2>Evaluaciones</h2></div></div>{pendingAssessments.length ? <ul class="simple-list">{pendingAssessments.map((assessment) => <li><span><strong>{assessment.title}</strong><small>Evaluación pendiente</small></span><a href={`/aula/${assessment.courseSlug}/evaluacion/${assessment.slug}`}>Realizar</a></li>)}</ul> : <p class="panel__empty">No tienes evaluaciones pendientes.</p>}</section>
  <section class="panel"><div class="panel__heading"><BookOpen /><div><span>Biblioteca</span><h2>Libros recomendados</h2></div></div>{recommendedBooks.length ? <ul class="simple-list">{recommendedBooks.map((book) => <li><span><strong>{book.title}</strong><small>{book.author}</small></span><a href={`/biblioteca/${book.slug}`}>Ver</a></li>)}</ul> : <p class="panel__empty">Inscríbete en un curso para recibir recomendaciones.</p>}</section>
  <section class="panel"><div class="panel__heading"><History /><div><span>Historial</span><h2>Actividad reciente</h2></div></div>{recentActivity.length ? <ul class="activity">{recentActivity.map((item) => <li><span>{item.type}</span><strong>{item.title}</strong><time datetime={item.date}>{new Intl.DateTimeFormat('es-PE',{dateStyle:'medium'}).format(new Date(item.date))}</time></li>)}</ul> : <p class="panel__empty">Tu actividad aparecerá aquí.</p>}</section>
  <section class="panel"><div class="panel__heading"><CheckCircle2 /><div><span>Completados</span><h2>Cursos terminados</h2></div></div>{finished.length ? <ul class="simple-list">{finished.map((item) => <li><span><strong>{item.course.title}</strong><small>100% completado</small></span><a href={`/cursos/${item.course.slug}`}>Revisar</a></li>)}</ul> : <p class="panel__empty">Todavía no has terminado un curso.</p>}</section>
  <section class="panel"><div class="panel__heading"><CalendarClock /><div><span>Logros</span><h2>Certificados</h2></div></div>{(certificateData ?? []).length ? <ul class="simple-list">{(certificateData ?? []).map((certificate:any) => <li><span><strong>{(Array.isArray(certificate.course)?certificate.course[0]:certificate.course)?.title}</strong><small>Nota final: {certificate.final_grade}%</small></span><a href={`/certificados/verificar/${certificate.verification_code}`}>Verificar</a></li>)}</ul> : <p class="panel__empty">Se emitirán al cumplir lecciones, evaluaciones y nota mínima.</p>}</section></div></div></main><Footer /></Layout>
<style>
  .dashboard{padding:calc(var(--header-height) + clamp(3rem,7vw,5rem)) 0 clamp(5rem,9vw,8rem);background:var(--color-gray-50)}.permission-alert{margin-bottom:1rem;padding:.8rem 1rem;border:1px solid #f1c7c7;border-radius:11px;background:#fff1f1;color:#9f3030;font-size:.8rem;font-weight:750}.dashboard__header{display:flex;justify-content:space-between;align-items:end;gap:1.5rem}.dashboard__header>div>span,.panel__heading span{color:var(--color-primary);font-size:.68rem;font-weight:800;text-transform:uppercase;letter-spacing:.08em}.dashboard__header h1{margin:.35rem 0;font-size:clamp(2.3rem,5vw,4rem)}.dashboard__header p{color:var(--color-text-secondary)}.dashboard__header>a{display:inline-flex;align-items:center;gap:.45rem;padding:.7rem 1rem;border:1px solid var(--color-border);border-radius:999px;background:var(--color-surface);font-size:.76rem;font-weight:750}.summary{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin:2rem 0}.summary article{display:grid;grid-template-columns:auto 1fr;gap:.1rem .65rem;padding:1rem;border:1px solid var(--color-border);border-radius:16px;background:var(--color-surface);box-shadow:var(--shadow-sm)}.summary svg{grid-row:1/3;color:var(--color-primary)}.summary strong{font:800 1.25rem var(--font-display)}.summary span{color:var(--color-text-secondary);font-size:.68rem}.dashboard-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}.panel{min-width:0;padding:clamp(1rem,3vw,1.5rem);border:1px solid var(--color-border);border-radius:var(--radius-xl);background:var(--color-surface);box-shadow:var(--shadow-sm)}.panel--wide{grid-column:1/-1}.panel__heading{display:flex;gap:.65rem;align-items:flex-start;margin-bottom:1.1rem}.panel__heading>svg{color:var(--color-primary)}.panel__heading h2{margin-top:.12rem;font-size:1.25rem}.course-list{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:.8rem}.course-progress{padding:1rem;border-radius:14px;background:var(--color-gray-50)}.course-progress>div{display:flex;justify-content:space-between;gap:1rem;font-size:.78rem}.course-progress>div strong{color:var(--color-primary-dark)}.course-progress progress{width:100%;height:7px;margin:.7rem 0;border:0;border-radius:99px;accent-color:var(--color-primary)}.course-progress p{color:var(--color-text-secondary);font-size:.68rem}.course-progress a,.empty a{display:inline-block;margin-top:.65rem;color:var(--color-primary);font-size:.72rem;font-weight:800}.simple-list,.activity{display:grid;gap:.65rem}.simple-list li{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.7rem;border-radius:11px;background:var(--color-gray-50)}.simple-list li>span{display:grid;min-width:0}.simple-list strong{overflow:hidden;font-size:.74rem;text-overflow:ellipsis;white-space:nowrap}.simple-list small,.activity time{color:var(--color-text-secondary);font-size:.64rem}.simple-list a{color:var(--color-primary);font-size:.68rem;font-weight:800}.activity li{display:grid;grid-template-columns:auto minmax(0,1fr) auto;align-items:center;gap:.6rem;padding-bottom:.6rem;border-bottom:1px solid var(--color-border)}.activity li>span{padding:.2rem .4rem;border-radius:6px;background:rgba(22,163,74,.1);color:var(--color-primary-dark);font-size:.58rem;font-weight:800}.activity strong{overflow:hidden;font-size:.7rem;text-overflow:ellipsis;white-space:nowrap}.panel__empty,.empty p{color:var(--color-text-secondary);font-size:.76rem}
  @media(max-width:850px){.summary{grid-template-columns:repeat(2,1fr)}.dashboard-grid{grid-template-columns:1fr}.panel--wide{grid-column:auto}}@media(max-width:520px){.dashboard__header{align-items:flex-start;flex-direction:column}.summary{grid-template-columns:1fr 1fr;gap:.6rem}.summary article{grid-template-columns:1fr}.summary svg{grid-row:auto}.activity li{grid-template-columns:auto 1fr}.activity time{grid-column:2}}
</style>

---
export const prerender = false;
import { Gamepad2, Plus } from '@lucide/astro';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminEmptyState from '../../../components/admin/AdminEmptyState.astro';
import AdminPageHeader from '../../../components/admin/AdminPageHeader.astro';
---

<AdminLayout title="Juegos educativos" description="Gestiona actividades interactivas para reforzar el aprendizaje." activeSection="games">
  <AdminPageHeader title="Juegos educativos" description="Integra experiencias interactivas dentro de las lecciones de la academia." eyebrow="Aprendizaje interactivo" actionHref="/admin/cursos" actionLabel="Crear juego">
    <Plus slot="action-icon" size={17} aria-hidden="true" />
  </AdminPageHeader>
  <AdminEmptyState title="No hay juegos administrativos todavía" description="Los juegos se añadirán desde el editor del curso o la lección donde serán utilizados." href="/admin/cursos" action="Seleccionar un curso">
    <Gamepad2 slot="icon" size={25} aria-hidden="true" />
  </AdminEmptyState>
</AdminLayout>

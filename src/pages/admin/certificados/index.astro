---
export const prerender = false;
import { Award, Settings } from '@lucide/astro';
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminEmptyState from '../../../components/admin/AdminEmptyState.astro';
import AdminPageHeader from '../../../components/admin/AdminPageHeader.astro';
---

<AdminLayout title="Certificados" description="Configura y supervisa las acreditaciones académicas." activeSection="certificates">
  <AdminPageHeader title="Certificados" description="Los certificados aparecerán cuando los estudiantes cumplan los requisitos académicos." eyebrow="Acreditaciones" actionHref="/admin/configuracion#certificados" actionLabel="Ver configuración">
    <Settings slot="action-icon" size={17} aria-hidden="true" />
  </AdminPageHeader>
  <AdminEmptyState title="No hay certificados emitidos todavía" description="La emisión se preparará desde la configuración cuando estén definidos los criterios de finalización." href="/admin/configuracion#certificados" action="Configurar certificados">
    <Award slot="icon" size={25} aria-hidden="true" />
  </AdminEmptyState>
</AdminLayout>

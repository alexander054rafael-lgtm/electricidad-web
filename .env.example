# Valores públicos del proyecto Supabase. Sustituye los placeholders localmente.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# URL pública de la aplicación, usada en enlaces de confirmación y recuperación.
PUBLIC_SITE_URL=http://localhost:4321

# Nunca añadas SUPABASE_SERVICE_ROLE_KEY a variables PUBLIC_* ni al navegador.

# OAuth 2.0 privado server-side para Google Drive.
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_DRIVE_FOLDER_ID=your-google-drive-folder-id
